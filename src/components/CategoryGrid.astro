---
import * as fs from 'node:fs';
import * as path from 'node:path';
import CategoryIcon from './CategoryIcon.astro';
import { t, getLocaleFromPath, getLangPrefix } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

// Count articles dynamically from knowledge/ directory
function countArticles(categorySlug: string): number {
  const categoryMap: Record<string, string> = {
    history: 'History', geography: 'Geography', culture: 'Culture', food: 'Food',
    art: 'Art', music: 'Music', technology: 'Technology', nature: 'Nature',
    people: 'People', society: 'Society', economy: 'Economy', lifestyle: 'Lifestyle'
  };
  const dirName = categoryMap[categorySlug] || categorySlug;
  const dirPath = path.join(process.cwd(), 'knowledge', dirName);
  try {
    const files = fs.readdirSync(dirPath);
    return files.filter(f => f.endsWith('.md') && !f.startsWith('_')).length;
  } catch {
    return 0;
  }
}

const categories = [
  { slug: 'history', cover: '/images/wiki/b5604a9d7dac.jpg' },
  { slug: 'geography', cover: '/images/wiki/3a0af3fa1cff.jpg' },
  { slug: 'culture', cover: '/images/wiki/c3f69037472b.jpg' },
  { slug: 'food', cover: '/images/wiki/6a7bed12c2a6.jpg' },
  { slug: 'art', cover: '/images/wiki/b92068ae92fb.jpg' },
  { slug: 'music', cover: '/images/wiki/dba145c33d6d.jpg' },
  { slug: 'technology', cover: '/images/wiki/f43072687967.jpg' },
  { slug: 'nature', cover: '/images/wiki/51510a8c6a50.jpg' },
  { slug: 'people', cover: '/images/wiki/4eadbb02099d.jpg' },
  { slug: 'society', cover: '/images/wiki/c18008c3ec52.jpg' },
  { slug: 'economy', cover: '/images/wiki/53ecc1645c5a.jpg' },
  { slug: 'lifestyle', cover: '/images/wiki/c1fb1b3a4b79.jpg' },
];

interface Props {
  lang?: Locale;
}

const { lang = getLocaleFromPath(Astro.url.pathname) } = Astro.props;
const prefix = getLangPrefix(lang);
const articleLabel = lang === 'en' ? 'articles' : lang === 'es' ? 'artículos' : '篇';
const exploreLabel = lang === 'en' ? 'Explore →' : lang === 'es' ? 'Explorar →' : '探索 →';
---

<section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 max-w-7xl mx-auto" id="categories" aria-label={t('nav.topics', lang)}>
  {categories.map((category) => {
    const count = countArticles(category.slug);
    const name = t(`cat.${category.slug}`, lang);
    const desc = t(`cat.${category.slug}.desc`, lang);
    const href = `${prefix}/${category.slug}`;
    return (
      <article>
        <a href={href} class="group card-hover block rounded-2xl overflow-hidden bg-white/90 border border-forest-100/40 no-underline" aria-label={name}>
          <div class="relative h-36 overflow-hidden">
            {category.cover ? (
              <img src={category.cover} alt={name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-forest-50">
                <CategoryIcon category={category.slug} class="w-10 h-10 text-forest-300" />
              </div>
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-forest/30 to-transparent"></div>
            <span class="absolute top-3 right-3 bg-white/90 backdrop-blur text-xs font-semibold text-forest-600 px-2.5 py-1 rounded-full shadow-sm">
              <span class="text-terracotta font-bold">{count}</span> {articleLabel}
            </span>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-forest mb-1.5 group-hover:text-teal transition-colors">{name}</h3>
            <p class="text-sm text-forest-400 leading-relaxed mb-3 flex-1">{desc}</p>
            <span class="text-sm font-semibold text-teal group-hover:text-teal-600 transition-colors">{exploreLabel}</span>
          </div>
        </a>
      </article>
    );
  })}
</section>
