---
interface Props {
  name: string;
  description: string;
  coverUrl: string;
  gradient: string;
  articleCount: number;
  homeHref: string;
  homeLabel: string;
  countSuffix?: string;
}

const { name, description, coverUrl, gradient, articleCount, homeHref, homeLabel, countSuffix = 'articles' } = Astro.props;
---

<section
  class="category-hero"
  style={coverUrl
    ? `background-image: url('${coverUrl}'); background-size: cover; background-position: center;`
    : `background: ${gradient};`
  }
>
  <div class="hero-overlay"></div>
  <div class="hero-inner">
    <nav class="hero-breadcrumb">
      <a href={homeHref} class="hero-bc-link">{homeLabel}</a>
      <span class="hero-bc-sep">›</span>
      <span class="hero-bc-current">{name}</span>
    </nav>
    <h1 class="hero-title">{name}</h1>
    <p class="hero-desc">{description}</p>
    <span class="hero-badge">{articleCount} {countSuffix}</span>
  </div>
</section>

<style>
  .category-hero {
    position: relative;
    width: 100%;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
  }

  @media (max-width: 768px) {
    .category-hero {
      min-height: 360px;
    }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.28) 0%, rgba(0,0,0,0.65) 100%);
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(6rem, 12vw, 9rem) 2rem 3rem;
    color: white;
  }

  .hero-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
  }

  .hero-bc-link {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.2s;
  }

  .hero-bc-link:hover {
    color: rgba(255,255,255,0.9);
  }

  .hero-bc-sep {
    color: rgba(255,255,255,0.4);
  }

  .hero-bc-current {
    color: rgba(255,255,255,0.65);
  }

  .hero-title {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 700;
    font-family: var(--font-editorial);
    line-height: 1.1;
    margin: 0 0 1rem 0;
    color: white;
  }

  .hero-desc {
    font-size: 1.2rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.8;
    max-width: 600px;
    margin: 0 0 1.5rem 0;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 0.375rem 1rem;
    border-radius: 999px;
    font-size: 0.875rem;
    color: white;
  }
</style>
