---
/**
 * JourneyCard — Premium travel magazine-style card with tall imagery
 */
interface Props {
  title: string;
  description: string;
  image: string;
  imageAlt: string;
  href: string;
  readTime: number;
  ctaText: string;
  readTimeLabel?: string;
  tall?: boolean;
}

const { title, description, image, imageAlt, href, readTime, ctaText, readTimeLabel = 'min', tall = false } = Astro.props;
---

<a
  href={href}
  class:list={[
    "group relative block rounded-2xl overflow-hidden",
    tall ? "h-[20rem] md:h-[28rem]" : "h-[18rem] md:h-[22rem]"
  ]}
  data-journey-card
>
  <!-- Full-bleed image -->
  <img
    src={image}
    alt={imageAlt}
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
    loading="lazy"
    decoding="async"
  />
  <!-- Gradient overlay — stronger at bottom for text legibility -->
  <div class="absolute inset-0 bg-gradient-to-t from-forest/80 via-forest/20 to-transparent"></div>

  <!-- Reading time badge -->
  <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm text-forest-600 text-xs font-medium px-3 py-1.5 rounded-full">
    {readTime} {readTimeLabel}
  </div>

  <!-- Bottom content overlay -->
  <div class="absolute inset-x-0 bottom-0 p-4 sm:p-6 md:p-8">
    <h3 class="text-2xl font-serif font-bold text-white leading-heading mb-2 group-hover:text-cream-100 transition-colors">
      {title}
    </h3>
    <p class="text-sm text-cream-200/80 leading-relaxed mb-4 line-clamp-2">
      {description}
    </p>
    <span class="inline-flex items-center gap-2 text-sm font-semibold text-teal-200 group-hover:gap-3 transition-all">
      {ctaText}
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
