---
interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  lang?: 'zh-TW' | 'en' | 'es';
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
}

const { lang = 'zh-TW' } = Astro.props;
const {
  title,
  description = lang === 'en'
    ? 'The open-source, AI-friendly knowledge base about Taiwan. 660+ pages covering history, culture, food, music, technology and more — written by the community, for the world.'
    : lang === 'es'
    ? 'La base de conocimiento de código abierto sobre Taiwán. Más de 660 páginas sobre historia, cultura, gastronomía, música, tecnología y más — escrita por la comunidad, para el mundo.'
    : '開源、AI-friendly 的台灣完整知識庫。660+ 頁深度內容涵蓋歷史、文化、美食、音樂、科技等 12 大主題，由社群共同編撰，讓全世界認識真正的台灣。',
  image = '/images/taiwan-social.jpg',
  url = Astro.url.href,
  type = 'website',
  datePublished,
  dateModified,
  content,
  tags,
  category,
} = Astro.props;

const fullTitle = `${title} | Taiwan.md`;
const siteUrl = 'https://taiwan.md';
const fullImageUrl = new URL(image, siteUrl).href;

// Generate AI-friendly summary from description or content
const aiSummary =
  description ||
  (content
    ? content
        .substring(0, 200)
        .replace(/[\n\r]/g, ' ')
        .replace(/[#*]/g, '')
        .trim() + '...'
    : '');

// Generate JSON-LD structured data
const generateJSONLD = () => {
  // Person pages (people category)
  if (category === 'people' || category === 'People') {
    return {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: title,
      description: description,
      url: url,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': url,
      },
      ...(datePublished && { birthDate: datePublished }),
    };
  }

  // Article pages
  if (type === 'article' && datePublished) {
    return {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description: description,
      author: {
        '@type': 'Organization',
        name: 'Taiwan.md',
        url: siteUrl,
      },
      publisher: {
        '@type': 'Organization',
        name: 'Taiwan.md',
        url: siteUrl,
        logo: {
          '@type': 'ImageObject',
          url: `${siteUrl}/images/taiwan-social.jpg`,
          width: 1200,
          height: 630,
        },
      },
      datePublished: datePublished,
      dateModified: dateModified || datePublished,
      inLanguage: lang,
      url: url,
      image: {
        '@type': 'ImageObject',
        url: fullImageUrl,
        width: 1200,
        height: 630,
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': url,
      },
      ...(tags && tags.length > 0 && { keywords: tags.join(', ') }),
      ...(category && { articleSection: category }),
    };
  }

  // Website root
  return {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: lang === 'en' ? 'Taiwan.md — Knowledge Base' : lang === 'es' ? 'Taiwan.md — Base de Conocimiento' : 'Taiwan.md - 台灣知識庫',
    description: lang === 'en'
      ? 'Open-source, AI-friendly knowledge base about Taiwan — politics, economy, culture, history, geography, and more.'
      : lang === 'es'
      ? 'Base de conocimiento de código abierto sobre Taiwán — política, economía, cultura, historia, geografía y más.'
      : '讓全世界完整認識台灣 - 開源台灣知識庫，蒐集關於台灣的政治、經濟、文化、歷史、地理等各方面知識。',
    url: siteUrl,
    inLanguage: lang,
    publisher: {
      '@type': 'Organization',
      name: 'Taiwan.md',
      url: siteUrl,
      logo: {
        '@type': 'ImageObject',
        url: `${siteUrl}/images/taiwan-social.jpg`,
        width: 1200,
        height: 630,
      },
    },
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${siteUrl}/search?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
    sameAs: [
      'https://github.com/frank890417/taiwan-md',
      'https://x.com/taiwandotmd',
      'https://www.instagram.com/taiwandotmd',
    ],
  };
};

const jsonLD = generateJSONLD();

// Organization Schema for all pages
const organizationLD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Taiwan.md',
  url: siteUrl,
  logo: `${siteUrl}/images/taiwan-social.jpg`,
  description: lang === 'en'
    ? 'Open-source, AI-friendly knowledge base about Taiwan'
    : lang === 'es'
    ? 'Base de conocimiento de código abierto sobre Taiwán'
    : '開源、AI-friendly 的台灣知識庫',
  foundingDate: '2024',
  sameAs: [
    'https://github.com/frank890417/taiwan-md',
    'https://x.com/taiwandotmd',
    'https://www.instagram.com/taiwandotmd',
    'https://www.threads.com/@taiwandotmd',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'cheyu.wu@monoame.com',
    contactType: 'Customer Support',
  },
};

// Dynamic keywords
const baseKeywords =
  lang === 'en'
    ? 'Taiwan, knowledge base, Taiwan history, Taiwan culture, Taiwan politics, Taiwan economy'
    : lang === 'es'
    ? 'Taiwán, base de conocimiento, historia de Taiwán, cultura de Taiwán, política de Taiwán'
    : '台灣, Taiwan, 台灣知識庫, 台灣歷史, 台灣文化, 台灣政治, 台灣經濟';

const categoryKeywords = category ?
  (lang === 'en' ?
    [`Taiwan ${category}`, `${category} Taiwan`] :
  lang === 'es' ?
    [`Taiwán ${category}`, `${category} Taiwán`] :
    [`台灣${category}`, `${category}台灣`]) : [];

const dynamicKeywords = [
  baseKeywords,
  ...categoryKeywords,
  ...(tags && tags.length > 0 ? tags : []),
].join(', ');

// BreadcrumbList JSON-LD for content pages
const generateBreadcrumbLD = () => {
  const currentPath = new URL(url).pathname;
  const isEn = lang === 'en';
  const isEs = lang === 'es';

  // Homepage - no breadcrumb needed
  if (currentPath === '/' || currentPath === '/en' || currentPath === '/en/' || currentPath === '/es' || currentPath === '/es/') {
    return null;
  }

  const homeItem = isEn ? `${siteUrl}/en` : isEs ? `${siteUrl}/es` : siteUrl;
  const baseItems = [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Taiwan.md',
      item: homeItem,
    }
  ];

  // Category page (e.g., /history, /en/culture, /es/historia)
  if (category && (currentPath.endsWith(`/${category}`) || currentPath.endsWith(`/${category}/`))) {
    return {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        ...baseItems,
        {
          '@type': 'ListItem',
          position: 2,
          name: category,
          item: url,
        },
      ],
    };
  }

  // Article page
  if (category && type === 'article') {
    const categoryUrl = isEn
      ? `${siteUrl}/en/${category}`
      : isEs
      ? `${siteUrl}/es/${category}`
      : `${siteUrl}/${category}`;
    return {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        ...baseItems,
        {
          '@type': 'ListItem',
          position: 2,
          name: category,
          item: categoryUrl,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: title,
          item: url,
        },
      ],
    };
  }

  // Other pages (about, contribute, etc.)
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      ...baseItems,
      {
        '@type': 'ListItem',
        position: 2,
        name: title,
        item: url,
      },
    ],
  };
};

const breadcrumbLD = generateBreadcrumbLD();

// OG locale map
const localeMap: Record<string, string> = { 'zh-TW': 'zh_TW', 'en': 'en_US', 'es': 'es_419' };
---

<!-- Basic Meta Tags -->
<meta name="description" content={description} />
<meta name="keywords" content={dynamicKeywords} />
<meta name="author" content="Taiwan.md" />
<meta name="generator" content="Astro" />
<meta name="theme-color" content="#3b82f6" />
<meta name="format-detection" content="telephone=no" />

<!-- Additional SEO Meta Tags -->
<meta name="revisit-after" content="7 days" />
<meta name="distribution" content="global" />
<meta name="rating" content="general" />

<!-- AI-friendly summary meta tag -->
<meta name="ai-summary" content={aiSummary} />

<!-- Canonical URL -->
<link rel="canonical" href={url} />

<!-- RSS Feed -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={lang === 'en' ? 'Taiwan.md RSS Feed (English)' : 'Taiwan.md RSS 動態消息'}
  href={`${siteUrl}/feed.xml`}
/>

<!-- Preconnect to external resources -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- DNS prefetch -->
<link rel="dns-prefetch" href="//github.com" />
<link rel="dns-prefetch" href="//x.com" />

<!-- Dynamic Language Tags -->
{(() => {
  const currentPath = new URL(url).pathname;
  let zhHref = siteUrl;
  let enHref = `${siteUrl}/en`;
  let esHref = `${siteUrl}/es`;

  if (currentPath !== '/' && currentPath !== '/en' && currentPath !== '/en/' && currentPath !== '/es' && currentPath !== '/es/') {
    if (currentPath.startsWith('/en/')) {
      enHref = url;
      const cleanPath = currentPath.replace('/en', '') || '/';
      zhHref = `${siteUrl}${cleanPath}`;
      esHref = `${siteUrl}/es${cleanPath}`;
    } else if (currentPath.startsWith('/es/')) {
      esHref = url;
      const cleanPath = currentPath.replace('/es', '') || '/';
      zhHref = `${siteUrl}${cleanPath}`;
      enHref = `${siteUrl}/en${cleanPath}`;
    } else {
      zhHref = url;
      enHref = `${siteUrl}/en${currentPath}`;
      esHref = `${siteUrl}/es${currentPath}`;
    }
  }

  return (
    <>
      <link rel="alternate" hreflang="zh-TW" href={zhHref} />
      <link rel="alternate" hreflang="en" href={enHref} />
      <link rel="alternate" hreflang="es" href={esHref} />
      <link rel="alternate" hreflang="x-default" href={zhHref} />
    </>
  );
})()}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:alt" content={`${title} - Taiwan.md 台灣知識庫`} />
<meta property="og:site_name" content="Taiwan.md — 台灣知識庫" />
<meta property="og:locale" content={localeMap[lang] || 'zh_TW'} />
{
  datePublished && (
    <meta property="article:published_time" content={datePublished} />
  )
}
{
  dateModified && (
    <meta property="article:modified_time" content={dateModified} />
  )
}
{
  tags &&
    tags.map((tag: string) => <meta property="article:tag" content={tag} />)
}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@cheyuwu345" />
<meta name="twitter:creator" content="@cheyuwu345" />
<meta name="twitter:url" content={url} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={`${title} - Taiwan.md 台灣知識庫`} />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLD, null, 2)} />
<script type="application/ld+json" set:html={JSON.stringify(organizationLD, null, 2)} />
{
  breadcrumbLD && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbLD, null, 2)}
    />
  )
}
