---
/**
 * SideTools — Floating sidebar with currency converter, visa check, and travel tips
 * Desktop: right sidebar floating. Mobile: expandable bottom drawer.
 */
import { t, getLocaleFromPath } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props {
  lang?: Locale;
}

const { lang = getLocaleFromPath(Astro.url.pathname) } = Astro.props;
---

<!-- Floating trigger button -->
<button
  class="fixed bottom-6 right-6 z-40 w-12 h-12 bg-teal text-white rounded-full shadow-lg hover:bg-teal-600 hover:shadow-xl transition-all flex items-center justify-center"
  id="sidetools-trigger"
  aria-label="Travel Tools"
>
  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
  </svg>
</button>

<!-- Side panel -->
<div id="sidetools-panel" class="fixed bottom-20 right-6 z-40 w-80 bg-white/95 backdrop-blur-xl border border-forest-100/50 rounded-2xl shadow-2xl hidden overflow-hidden">
  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-3 border-b border-forest-100/30">
    <h3 class="text-sm font-semibold text-forest">Travel Tools</h3>
    <button class="text-forest-400 hover:text-forest transition-colors" id="sidetools-close" aria-label="Close">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="p-5 space-y-5 max-h-[60vh] overflow-y-auto">
    <!-- Currency Converter -->
    <div>
      <h4 class="text-xs font-semibold text-forest-400 uppercase tracking-wider mb-2">{t('tools.currency', lang)}</h4>
      <div class="flex items-center gap-2">
        <input
          type="number"
          id="currency-amount"
          value="1000"
          min="0"
          class="flex-1 px-3 py-2 text-sm bg-forest-50 border border-forest-100 rounded-lg text-forest focus:outline-none focus:ring-2 focus:ring-teal/30"
          aria-label="Amount in TWD"
        />
        <span class="text-xs text-forest-400">TWD</span>
      </div>
      <div class="mt-2 grid grid-cols-3 gap-2 text-center">
        <div class="bg-forest-50 rounded-lg px-2 py-1.5">
          <div class="text-xs text-forest-400">USD</div>
          <div class="text-sm font-medium text-forest" id="conv-usd">—</div>
        </div>
        <div class="bg-forest-50 rounded-lg px-2 py-1.5">
          <div class="text-xs text-forest-400">EUR</div>
          <div class="text-sm font-medium text-forest" id="conv-eur">—</div>
        </div>
        <div class="bg-forest-50 rounded-lg px-2 py-1.5">
          <div class="text-xs text-forest-400">JPY</div>
          <div class="text-sm font-medium text-forest" id="conv-jpy">—</div>
        </div>
      </div>
    </div>

    <!-- Quick Travel Tips -->
    <div>
      <h4 class="text-xs font-semibold text-forest-400 uppercase tracking-wider mb-2">{t('tools.tips', lang)}</h4>
      <div class="space-y-2 text-sm text-forest-600">
        <details class="group">
          <summary class="cursor-pointer font-medium hover:text-teal transition-colors">Power & Plugs</summary>
          <p class="mt-1 text-xs text-forest-400 pl-4">110V / 60Hz, Type A & B plugs (same as USA/Japan)</p>
        </details>
        <details class="group">
          <summary class="cursor-pointer font-medium hover:text-teal transition-colors">Tipping</summary>
          <p class="mt-1 text-xs text-forest-400 pl-4">Not expected. 10% service charge at upscale restaurants.</p>
        </details>
        <details class="group">
          <summary class="cursor-pointer font-medium hover:text-teal transition-colors">Transit Cards</summary>
          <p class="mt-1 text-xs text-forest-400 pl-4">EasyCard or iPASS — works on MRT, buses, convenience stores.</p>
        </details>
        <details class="group">
          <summary class="cursor-pointer font-medium hover:text-teal transition-colors">Emergency</summary>
          <p class="mt-1 text-xs text-forest-400 pl-4">Police: 110 · Fire/Ambulance: 119 · Tourist Hotline: 0800-024-111</p>
        </details>
        <details class="group">
          <summary class="cursor-pointer font-medium hover:text-teal transition-colors">Best Time to Visit</summary>
          <p class="mt-1 text-xs text-forest-400 pl-4">Oct–Dec & Mar–May (mild weather, fewer typhoons)</p>
        </details>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var trigger = document.getElementById('sidetools-trigger');
  var panel = document.getElementById('sidetools-panel');
  var close = document.getElementById('sidetools-close');
  var amountInput = document.getElementById('currency-amount');

  if (trigger && panel) {
    trigger.addEventListener('click', function() {
      panel.classList.toggle('hidden');
    });
  }
  if (close && panel) {
    close.addEventListener('click', function() {
      panel.classList.add('hidden');
    });
  }

  // Simple currency conversion (approximate rates, updated periodically)
  var rates = { USD: 0.031, EUR: 0.029, JPY: 4.7 };

  function convert() {
    var amount = parseFloat(amountInput.value) || 0;
    document.getElementById('conv-usd').textContent = '$' + (amount * rates.USD).toFixed(2);
    document.getElementById('conv-eur').textContent = '€' + (amount * rates.EUR).toFixed(2);
    document.getElementById('conv-jpy').textContent = '¥' + Math.round(amount * rates.JPY);
  }

  if (amountInput) {
    amountInput.addEventListener('input', convert);
    convert(); // Initial conversion
  }

  // Try to fetch live rates (free API, no key needed)
  fetch('https://api.exchangerate-api.com/v4/latest/TWD')
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.rates) {
        rates.USD = data.rates.USD || rates.USD;
        rates.EUR = data.rates.EUR || rates.EUR;
        rates.JPY = data.rates.JPY || rates.JPY;
        convert();
      }
    })
    .catch(function() { /* Use fallback rates */ });
})();
</script>
