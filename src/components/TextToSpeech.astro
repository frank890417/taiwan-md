---
/**
 * TextToSpeech — Browser SpeechSynthesis TTS button for articles
 * Language-aware: picks appropriate voice for zh-TW, en, es
 */
import { t, getLocaleFromPath } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props {
  lang?: Locale;
}

const { lang = getLocaleFromPath(Astro.url.pathname) } = Astro.props;

const speechLangMap: Record<string, string> = {
  'zh-TW': 'zh-TW',
  en: 'en-US',
  es: 'es-419',
};
const speechLang = speechLangMap[lang] || 'en-US';
---

<div class="tts-controls flex items-center gap-2" id="tts-controls" data-speech-lang={speechLang}>
  <button
    class="btn-ghost text-sm flex items-center gap-1.5"
    id="tts-play"
    aria-label={t('article.tts.play', lang)}
    title={t('article.tts.play', lang)}
  >
    <svg class="w-4 h-4" id="tts-icon-play" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
    </svg>
    <svg class="w-4 h-4 hidden" id="tts-icon-pause" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span id="tts-label">{t('article.tts.play', lang)}</span>
  </button>
  <button
    class="btn-ghost text-sm hidden"
    id="tts-stop"
    aria-label={t('article.tts.stop', lang)}
    title={t('article.tts.stop', lang)}
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M9 10a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z" />
    </svg>
  </button>
</div>

<script is:inline>
(function() {
  if (!('speechSynthesis' in window)) {
    var controls = document.getElementById('tts-controls');
    if (controls) controls.style.display = 'none';
    return;
  }

  var synth = window.speechSynthesis;
  var playBtn = document.getElementById('tts-play');
  var stopBtn = document.getElementById('tts-stop');
  var iconPlay = document.getElementById('tts-icon-play');
  var iconPause = document.getElementById('tts-icon-pause');
  var label = document.getElementById('tts-label');
  var controls = document.getElementById('tts-controls');
  var speechLang = controls ? controls.getAttribute('data-speech-lang') : 'en-US';
  var utterance = null;
  var isPlaying = false;

  function getArticleText() {
    var article = document.querySelector('[data-pagefind-body]') || document.querySelector('article') || document.querySelector('.prose');
    if (!article) return '';
    return article.innerText || article.textContent || '';
  }

  function setState(state) {
    isPlaying = state === 'playing';
    if (state === 'playing') {
      iconPlay.classList.add('hidden');
      iconPause.classList.remove('hidden');
      stopBtn.classList.remove('hidden');
      label.textContent = 'Pause';
    } else if (state === 'paused') {
      iconPlay.classList.remove('hidden');
      iconPause.classList.add('hidden');
      label.textContent = 'Resume';
    } else {
      iconPlay.classList.remove('hidden');
      iconPause.classList.add('hidden');
      stopBtn.classList.add('hidden');
      label.textContent = controls.querySelector('[id="tts-play"]').getAttribute('aria-label');
    }
  }

  if (playBtn) {
    playBtn.addEventListener('click', function() {
      if (synth.speaking && !synth.paused) {
        synth.pause();
        setState('paused');
        return;
      }
      if (synth.paused) {
        synth.resume();
        setState('playing');
        return;
      }
      var text = getArticleText();
      if (!text) return;

      // Split into chunks (max ~200 chars at sentence boundaries for reliability)
      utterance = new SpeechSynthesisUtterance(text.substring(0, 5000));
      utterance.lang = speechLang;
      utterance.rate = 0.95;
      utterance.pitch = 1;

      utterance.onend = function() { setState('idle'); };
      utterance.onerror = function() { setState('idle'); };

      synth.speak(utterance);
      setState('playing');
    });
  }

  if (stopBtn) {
    stopBtn.addEventListener('click', function() {
      synth.cancel();
      setState('idle');
    });
  }
})();
</script>
