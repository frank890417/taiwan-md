---
import SEO from '../components/SEO.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import LanguageBanner from '../components/LanguageBanner.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';
import { getLocaleFromPath, getLangPrefix } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  image?: string;
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
}

const { title, description = '讓全世界完整認識台灣', lang = getLocaleFromPath(Astro.url.pathname), image, type, datePublished, dateModified, content, tags, category } = Astro.props;

// Build search index at build time
const categoryMapping: Record<string, string> = {
  'history': 'History', 'geography': 'Geography', 'culture': 'Culture',
  'food': 'Food', 'art': 'Art', 'music': 'Music', 'technology': 'Technology',
  'nature': 'Nature', 'people': 'People', 'society': 'Society',
  'economy': 'Economy', 'lifestyle': 'Lifestyle'
};

const searchIndex: Array<{t: string; d: string; u: string; tags: string[]; lang: string}> = [];

for (const [slug, folder] of Object.entries(categoryMapping)) {
  // Chinese articles
  try {
    const zhPath = resolve(process.cwd(), 'knowledge', folder);
    const files = await readdir(zhPath);
    for (const file of files.filter(f => f.endsWith('.md') && !f.startsWith('_'))) {
      const { data } = matter(await readFile(join(zhPath, file), 'utf-8'));
      const name = basename(file, '.md');
      searchIndex.push({
        t: data.title || name,
        d: data.description || '',
        u: `/${slug}/${name}`,
        tags: data.tags || [],
        lang: 'zh-TW'
      });
    }
  } catch {}
  // English articles
  try {
    const enPath = resolve(process.cwd(), 'knowledge', 'en', folder);
    const files = await readdir(enPath);
    for (const file of files.filter(f => f.endsWith('.md') && !f.startsWith('_'))) {
      const { data } = matter(await readFile(join(enPath, file), 'utf-8'));
      const name = basename(file, '.md');
      searchIndex.push({
        t: data.title || name,
        d: data.description || '',
        u: `/en/${slug}/${name}`,
        tags: data.tags || [],
        lang: 'en'
      });
    }
  } catch {}
  // Spanish articles
  try {
    const esPath = resolve(process.cwd(), 'knowledge', 'es', folder);
    const files = await readdir(esPath);
    for (const file of files.filter(f => f.endsWith('.md') && !f.startsWith('_'))) {
      const { data } = matter(await readFile(join(esPath, file), 'utf-8'));
      const name = basename(file, '.md');
      searchIndex.push({
        t: data.title || name,
        d: data.description || '',
        u: `/es/${slug}/${name}`,
        tags: data.tags || [],
        lang: 'es'
      });
    }
  } catch {}
}

const prefix = getLangPrefix(lang);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif+TC:wght@400;600;700;900&display=swap" rel="stylesheet" />
    <title>{title} | Taiwan.md</title>
    <SEO title={title} description={description} lang={lang} image={image} type={type} datePublished={datePublished} dateModified={dateModified} content={content} tags={tags} category={category} />
    <ClientRouter />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JGC5W00N7T"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JGC5W00N7T');
    </script>
  </head>
    <body class="font-sans leading-relaxed text-forest bg-gradient-to-b from-white to-cream-50 antialiased">
    <LanguageBanner lang={lang} />
    <Navbar lang={lang} />
    <SearchModal searchIndex={searchIndex} lang={lang} />

    <main role="main" class="min-h-[calc(100vh-4rem)]" data-pagefind-body>
      <slot />
    </main>

    <Footer lang={lang} />

    <!-- Floating .md button -->
    <a id="md-btn" class="fixed bottom-6 left-6 z-40 w-12 h-12 bg-forest text-teal rounded-xl flex items-center justify-center font-mono text-sm font-bold no-underline shadow-card hover:-translate-y-0.5 hover:shadow-lg hover:bg-teal hover:text-white transition-all" title="Edit on GitHub" target="_blank">
      .md
    </a>

    <script is:inline>
      // Set .md button href based on current path
      const btn = document.getElementById('md-btn');
      const pathname = window.location.pathname;
      const ghBase = 'https://github.com/frank890417/taiwan-md/edit/main';
      
      let target = '/README.md';

      if (pathname === '/' || pathname === '/en' || pathname === '/en/' || pathname === '/es' || pathname === '/es/' || pathname === '/index.html') {
        target = '/README.md';
      } else if (pathname.includes('/contribute')) {
        target = '/CONTRIBUTING.md';
      } else if (pathname.includes('/resources')) {
        target = '/knowledge/About/台灣官方網站資源.md';
      } else if (pathname.includes('/graph')) {
        target = '/src/pages/graph.astro';
      } else if (pathname.includes('/map')) {
        target = pathname.startsWith('/en') ? '/src/pages/en/map.astro' : '/src/pages/map.astro';
      } else if (pathname.includes('/about')) {
        target = '/src/pages/about.astro';
      } else {
        const isEn = pathname.startsWith('/en/');
        const isEs = pathname.startsWith('/es/');
        const cleanPath = pathname.replace(/^\/(en|es)/, '').replace(/^\//, '').replace(/\/$/, '').replace('index.html', '');
        const parts = cleanPath.split('/');
        
        if (parts.length > 0 && parts[0]) {
          const cat = parts[0];
          const catFolder = cat.charAt(0).toUpperCase() + cat.slice(1);
          const prefix = isEn ? '/knowledge/en' : isEs ? '/knowledge/es' : '/knowledge';
          
          if (parts.length === 1) {
            target = `${prefix}/${catFolder}/_${catFolder} Hub.md`;
          } else {
            const slug = decodeURIComponent(parts.slice(1).join('/')); 
            target = `${prefix}/${catFolder}/${slug}.md`;
          }
        }
      }
      
      btn.href = ghBase + target;
    </script>
    <script is:inline>
      // Scroll-triggered animations
      (function() {
        var els = document.querySelectorAll('.animate-on-scroll');
        if (!els.length || !('IntersectionObserver' in window)) {
          els.forEach(function(el) { el.classList.add('visible'); });
          return;
        }
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });
        els.forEach(function(el) { observer.observe(el); });
      })();
    </script>
  </body>
</html>

<style is:global>
  /* Image constraints for article content */
  main img {
    max-width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
  }

  /* Global link styles for article prose content only */
  main .prose a:not(.nav-link):not(.btn-primary):not(.btn-secondary):not(.btn-ghost):not([class*="btn"]) {
    color: theme('colors.teal.DEFAULT');
    text-decoration: none;
    border-bottom: 1px solid theme('colors.teal.200');
    padding-bottom: 1px;
    transition: all 0.2s ease;
  }
  main .prose a:not(.nav-link):not(.btn-primary):not(.btn-secondary):not(.btn-ghost):not([class*="btn"]):hover {
    color: theme('colors.forest.DEFAULT');
    border-bottom-color: theme('colors.teal.DEFAULT');
  }
  /* External links get an icon */
  main .prose a[target="_blank"]::after {
    content: '↗';
    font-size: 0.8em;
    margin-left: 0.2em;
    opacity: 0.7;
  }
</style>
