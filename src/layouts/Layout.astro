---
import SEO from '../components/SEO.astro';
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import matter from 'gray-matter';
import { useTranslatedPath } from '../i18n/utils';
import type { Lang } from '../types';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  image?: string;
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
}

const {
  title,
  description = '讓全世界完整認識台灣',
  lang = 'zh-TW',
  image,
  type,
  datePublished,
  dateModified,
  content,
  tags,
  category,
} = Astro.props;

// Build search index at build time
const categoryMapping: Record<string, string> = {
  history: 'History',
  geography: 'Geography',
  culture: 'Culture',
  food: 'Food',
  art: 'Art',
  music: 'Music',
  technology: 'Technology',
  nature: 'Nature',
  people: 'People',
  society: 'Society',
  economy: 'Economy',
  lifestyle: 'Lifestyle',
};

const searchIndex: Array<{
  t: string;
  d: string;
  u: string;
  tags: string[];
  lang: string;
}> = [];

for (const [slug, folder] of Object.entries(categoryMapping)) {
  // Chinese articles
  try {
    const zhPath = resolve(process.cwd(), 'knowledge', folder);
    const files = await readdir(zhPath);
    for (const file of files.filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    )) {
      const { data } = matter(await readFile(join(zhPath, file), 'utf-8'));
      const name = basename(file, '.md');
      searchIndex.push({
        t: data.title || name,
        d: data.description || '',
        u: `/${slug}/${name}`,
        tags: data.tags || [],
        lang: 'zh-TW',
      });
    }
  } catch {}
  // English articles
  try {
    const enPath = resolve(process.cwd(), 'knowledge', 'en', folder);
    const files = await readdir(enPath);
    for (const file of files.filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    )) {
      const { data } = matter(await readFile(join(enPath, file), 'utf-8'));
      const name = basename(file, '.md');
      searchIndex.push({
        t: data.title || name,
        d: data.description || '',
        u: `/en/${slug}/${name}`,
        tags: data.tags || [],
        lang: 'en',
      });
    }
  } catch {}
}
const currentPath = Astro.url.pathname;
const isEn = lang === 'en';

const translatePath = useTranslatedPath('en');

const enLink = translatePath(currentPath);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;700;900&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Taiwan.md</title>
    <SEO
      title={title}
      description={description}
      lang={lang}
      image={image}
      type={type}
      datePublished={datePublished}
      dateModified={dateModified}
      content={content}
      tags={tags}
      category={category}
    />
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-JGC5W00N7T"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());
      gtag('config', 'G-JGC5W00N7T');
    </script>
  </head>
  <body>
    <div id="lang-banner" class="lang-banner" style="display:none;">
      <span
        >🌐 English version available → <a href={enLink}>Switch to English</a
        ></span
      >
      <button
        class="lang-banner-close"
        onclick="document.getElementById('lang-banner').style.display='none';localStorage.setItem('lang-banner-dismissed','1');"
        aria-label="Close">✕</button
      >
    </div>
    <script is:inline>
      (function () {
        if (localStorage.getItem('lang-banner-dismissed')) return;
        var lang = navigator.language || navigator.userLanguage || '';
        if (lang.startsWith('zh')) return;
        if (window.location.pathname.startsWith('/en')) return;
        var b = document.getElementById('lang-banner');
        if (b) b.style.display = 'flex';
      })();
    </script>
    <Header />

    <script is:inline define:vars={{ searchIndex, isEn }}>
      (function () {
        var idx = searchIndex;
        var lang = isEn ? 'en' : 'zh-TW';
        var input = document.getElementById('search-input');
        var results = document.getElementById('search-results');
        var modal = document.getElementById('search-modal');

        input.addEventListener('input', function () {
          var q = this.value.trim().toLowerCase();
          if (!q) {
            results.innerHTML =
              '<div class="search-hint">' +
              (isEn
                ? 'Type to search across all articles'
                : '輸入關鍵字搜尋所有文章') +
              '</div>';
            return;
          }
          var matches = idx.filter(function (item) {
            return (
              item.t.toLowerCase().indexOf(q) !== -1 ||
              item.d.toLowerCase().indexOf(q) !== -1 ||
              item.tags.some(function (tag) {
                return tag.toLowerCase().indexOf(q) !== -1;
              })
            );
          });
          // Prefer current language, then show others
          matches.sort(function (a, b) {
            var aLang = a.lang === lang ? 0 : 1;
            var bLang = b.lang === lang ? 0 : 1;
            return aLang - bLang;
          });
          if (matches.length === 0) {
            results.innerHTML =
              '<div class="search-hint">' +
              (isEn ? 'No results found' : '找不到相關文章') +
              '</div>';
            return;
          }
          var html = matches
            .slice(0, 12)
            .map(function (item) {
              var langBadge = item.lang === 'en' ? 'EN' : '中';
              return (
                '<a class="search-item" href="' +
                item.u +
                '">' +
                '<span class="search-item-lang">' +
                langBadge +
                '</span>' +
                '<div class="search-item-text">' +
                '<span class="search-item-title">' +
                item.t +
                '</span>' +
                (item.d
                  ? '<span class="search-item-desc">' + item.d + '</span>'
                  : '') +
                '</div>' +
                '</a>'
              );
            })
            .join('');
          if (matches.length > 12) {
            html +=
              '<div class="search-hint">' +
              (isEn
                ? '...and ' + (matches.length - 12) + ' more'
                : '...還有 ' + (matches.length - 12) + ' 篇') +
              '</div>';
          }
          results.innerHTML = html;
        });

        // ESC to close
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && modal.classList.contains('open')) {
            modal.classList.remove('open');
          }
          // Cmd/Ctrl+K to open
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            modal.classList.toggle('open');
            if (modal.classList.contains('open')) {
              setTimeout(function () {
                input.focus();
              }, 100);
            }
          }
        });
      })();
    </script>

    <main role="main">
      <slot />
    </main>

    <Footer />

    <!-- Floating .md button -->
    <a
      id="md-btn"
      class="floating-md"
      title="查看 Raw Markdown 版本"
      target="_blank"
    >
      .md
    </a>

    <script is:inline>
      // Set .md button href based on current path
      const btn = document.getElementById('md-btn');
      const pathname = window.location.pathname;
      const ghBase = 'https://github.com/frank890417/taiwan-md/blob/main';

      let target = '/README.md'; // Default fallback

      // Handle special pages
      if (
        pathname === '/' ||
        pathname === '/en' ||
        pathname === '/en/' ||
        pathname === '/index.html'
      ) {
        target = '/README.md';
      } else if (pathname.includes('/contribute')) {
        target = '/CONTRIBUTING.md';
      } else if (pathname.includes('/resources')) {
        target = '/knowledge/About/台灣官方網站資源.md';
      } else if (pathname.includes('/graph')) {
        target = '/src/pages/graph.astro';
      } else if (pathname.includes('/map')) {
        target = pathname.startsWith('/en')
          ? '/src/pages/en/map.astro'
          : '/src/pages/map.astro';
      } else if (pathname.includes('/about')) {
        target = '/src/pages/about.astro';
      } else {
        // Content pages (Categories or Articles)
        const isEn = pathname.startsWith('/en/');
        // Remove /en/ prefix and leading/trailing slashes
        const cleanPath = pathname
          .replace(/^\/en/, '')
          .replace(/^\//, '')
          .replace(/\/$/, '')
          .replace('index.html', '');
        const parts = cleanPath.split('/');

        if (parts.length > 0 && parts[0]) {
          const cat = parts[0];
          // Capitalize first letter of category (history -> History)
          const catFolder = cat.charAt(0).toUpperCase() + cat.slice(1);

          // ZH source is in knowledge/Category, EN source is in knowledge/en/Category
          const prefix = isEn ? '/knowledge/en' : '/knowledge';

          if (parts.length === 1) {
            // Category Hub: knowledge/History/_History Hub.md
            target = `${prefix}/${catFolder}/_${catFolder} Hub.md`;
          } else {
            // Article: knowledge/History/article-name.md
            const slug = decodeURIComponent(parts.slice(1).join('/'));
            target = `${prefix}/${catFolder}/${slug}.md`;
          }
        }
      }

      btn.href = ghBase + target;

      // Hash-based active state can only be detected client-side
      if (window.location.hash === '#categories') {
        document
          .querySelectorAll('.nav-link[href$="/#categories"]')
          .forEach((l) => l.classList.add('active'));
      }
    </script>
  </body>
</html>

<style is:global>
  html {
    font-size: 118%;
  }
  :root {
    --container-wide: 1380px;
    --container-page: 1180px;
    --container-reading: 1080px;
    --space-page-x: clamp(1rem, 2vw, 2rem);
    --space-section-y: clamp(3.5rem, 7vw, 6rem);
    --space-1: 0.5rem;
    --space-2: 0.75rem;
    --space-3: 1rem;
    --space-4: 1.5rem;
    --space-5: 2rem;
    --space-6: 2.5rem;
    --space-7: 3rem;
    --space-8: 4rem;
    --space-9: 5rem;
    --radius-chip: 16px;
    --radius-card: 20px;
    --radius-pill: 999px;
    --shadow-soft: 0 8px 30px rgba(15, 23, 42, 0.06);
    --shadow-card: 0 16px 40px rgba(15, 23, 42, 0.08);
    --border-soft: 1px solid rgba(148, 163, 184, 0.2);
    --font-editorial: 'Noto Serif TC', 'Source Han Serif TC', 'PMingLiU', serif;
    --title-display-size: clamp(2.25rem, 5vw, 3.2rem);
    --title-section-size: clamp(1.95rem, 4vw, 2.5rem);
    --title-subsection-size: clamp(1.3rem, 2.4vw, 1.7rem);
    --title-minor-size: 1.1rem;
    --title-line-height: 1.2;
    --title-letter-spacing: 0.03em;
    --copy-intro-size: clamp(1rem, 1.6vw, 1.08rem);
    --copy-intro-line: 1.75;
    --copy-intro-color: #64748b;
    --copy-intro-width: 42rem;
  }
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* Focus styles for keyboard accessibility */
  *:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  button:focus-visible,
  a:focus-visible,
  input:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }
  .lang-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    background: linear-gradient(90deg, #1e3a5f, #2563eb);
    color: white;
    font-size: 0.85rem;
    text-align: center;
  }
  .lang-banner a {
    color: #fbbf24;
    font-weight: 600;
    text-decoration: underline;
  }
  .lang-banner a:hover {
    color: #fde68a;
  }
  .lang-banner-close {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1rem;
    cursor: pointer;
    padding: 0 0.3rem;
  }
  .lang-banner-close:hover {
    color: white;
  }

  body {
    font-family: 'Noto Serif TC', 'Source Han Serif TC', 'PMingLiU', serif;
    font-weight: 600;
    line-height: 1.6;
    color: #1a1a2e;
    background:
      radial-gradient(
        circle at top,
        rgba(226, 232, 240, 0.35),
        transparent 30%
      ),
      linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    -webkit-font-smoothing: antialiased;
  }

  /* Main - full width */
  main {
    min-height: calc(100vh - 60px);
  }
  main img {
    max-width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 12px;
  }

  /* Global link styles */
  main
    a:not(.nav-link):not(.btn-primary):not(.btn-secondary):not(.card-link):not(
      .logo
    ):not(.category-card):not(.lang-btn):not(.floating-md):not(.search-item) {
    color: #475569;
    text-decoration: none;
    border-bottom: 1px solid #cbd5e1;
    padding-bottom: 1px;
    transition: all 0.2s ease;
  }
  main
    a:not(.nav-link):not(.btn-primary):not(.btn-secondary):not(.card-link):not(
      .logo
    ):not(.category-card):not(.lang-btn):not(.floating-md):not(
      .search-item
    ):hover {
    color: #1a1a2e;
    border-bottom-color: #64748b;
  }
  /* External links (with target="_blank") get an icon */
  main
    a[target='_blank']:not(.nav-link):not(.btn-primary):not(.btn-secondary):not(
      .card-link
    ):not(.logo):not(.category-card):not(.lang-btn):not(.floating-md)::after {
    content: '↗';
    font-size: 0.8em;
    margin-left: 0.2em;
    opacity: 0.7;
  }

  /* Footer */
  footer {
    background: #1a2e1a;
    color: #94a3b8;
    padding: 3rem 0 1.5rem;
  }
  .footer-inner {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--space-page-x);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .footer-logo {
    font-size: 1.2rem;
    font-weight: 700;
    color: white;
    display: block;
    margin-bottom: 0.5rem;
  }
  .footer-heart {
    color: #22c55e;
    margin-top: 0.5rem;
  }
  .footer-license {
    margin-top: 0.75rem;
  }
  .footer-license a {
    color: #a7c7a7;
    text-decoration: none;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    transition: all 0.2s ease;
  }
  .footer-license a:hover {
    color: #c7d2c7;
  }
  .footer-eth {
    margin-top: 0.6rem;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .footer-eth-label {
    color: #94a3b8;
  }
  .footer-eth-address {
    font-family: 'SF Mono', 'Fira Code', monospace;
    color: #a7c7a7;
    font-size: 0.8rem;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.02em;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-col h4 {
    color: white;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .footer-col a {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.2s ease;
    position: relative;
    padding: 0.25rem 0;
  }
  .footer-col a:hover {
    color: #e2e8f0;
    text-decoration: none;
  }
  .footer-col a:hover::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: #a7c7a7;
    opacity: 0.7;
  }
  .footer-bottom {
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid #1e293b;
    font-size: 0.8rem;
  }

  /* Floating .md button */
  .floating-md {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 48px;
    height: 48px;
    background: #1a1a2e;
    color: #3b82f6;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: var(--shadow-card);
    transition: all 0.2s;
    z-index: 40;
  }
  .floating-md:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.3);
    background: #3b82f6;
    color: white;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    font-size: 1.4rem;
    cursor: pointer;
    color: #334155;
    padding: 0.25rem;
  }
  .nav-mobile {
    display: none;
  }
  @media (max-width: 768px) {
    .header-inner {
      padding: 0.7rem 1rem;
      gap: 0.75rem;
    }
    .logo {
      font-size: 1.05rem;
    }
    .nav-desktop {
      display: none;
    }
    .menu-toggle {
      display: block;
      order: 4;
      margin-left: 0.15rem;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 999px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
    }
    .search-toggle {
      order: 2;
    }
    .lang-toggle {
      order: 3;
      margin-left: auto;
    }
    .search-panel {
      max-width: 100%;
      width: 95%;
    }
    .search-modal {
      padding-top: 8vh;
    }
    .nav-mobile {
      display: none;
      position: absolute;
      top: 100%;
      left: 0.75rem;
      right: 0.75rem;
      margin-top: 0.35rem;
      background: rgba(255, 255, 255, 0.99);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      flex-direction: column;
      padding: 0.8rem 1rem 1rem;
      gap: 0;
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 18px;
      box-shadow: 0 18px 42px rgba(15, 23, 42, 0.14);
    }
    .nav-mobile.open {
      display: flex;
    }
    .nav-mobile .nav-link {
      padding: 0.85rem 0.2rem;
      font-size: 0.95rem;
      border-bottom: 1px solid #f1f5f9;
      position: relative;
      border-radius: 0;
      background: transparent;
    }
    .nav-mobile .nav-link:hover::after {
      display: none; /* 移動端不顯示底線效果 */
    }
    .nav-mobile .nav-link.active {
      color: #1a1a2e;
      font-weight: 600;
      background: rgba(59, 130, 246, 0.05);
      margin: 0 -1rem;
      padding-left: 1rem;
      padding-right: 1rem;
      border-radius: 8px;
    }
    .mobile-lang-toggle {
      padding: 1rem 0 0.5rem;
      border-top: 1px solid #e2e8f0;
    }
    .mobile-lang-label {
      font-size: 0.85rem;
      color: #64748b;
      font-weight: 500;
      display: block;
      margin-bottom: 0.75rem;
    }
    .mobile-lang-buttons {
      display: flex;
      gap: 0.5rem;
    }
    .mobile-lang-btn {
      flex: 1;
      padding: 0.6rem;
      text-align: center;
      text-decoration: none;
      color: #475569;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 600;
      transition: all 0.2s;
    }
    .mobile-lang-btn.active {
      background: #3b82f6;
      color: white;
      border-color: #3b82f6;
    }
    .mobile-lang-btn:not(.active):hover {
      background: #e2e8f0;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.75rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .floating-md {
      bottom: 1rem;
      right: 1rem;
      width: 42px;
      height: 42px;
      font-size: 0.78rem;
    }
    footer {
      padding: 2.5rem 0 1.25rem;
    }
    .footer-inner {
      padding: 0 1.25rem;
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
