---

<Layout title="404 | Taiwan.md">
  <main class="error-page" style="opacity: 0; transition: opacity 0.15s;">
    <!-- Generic 404 -->
    <div class="error-content" id="notfound-generic">
      <h1 class="error-code">404</h1>
      <p class="error-title" data-i18n="generic.title">這個頁面不存在</p>
      <p class="error-desc" data-i18n="generic.desc">
        可能是連結過期、文章被移動，或是網址打錯了。
      </p>

      <div class="error-actions">
        <a href="/" class="btn btn-primary" id="back-link" data-i18n-text="back"
          >← 回首頁</a
        >
        <a href="/graph" class="btn btn-secondary">🕸️ Knowledge Graph</a>
      </div>

      <div class="search-section">
        <p data-i18n="search.prompt">試試搜尋你要找的內容：</p>
        <form
          action="https://www.google.com/search"
          method="get"
          target="_blank"
          class="search-form"
        >
          <input type="hidden" name="q" value="site:taiwan.md" />
          <input
            type="text"
            name="q"
            placeholder="搜尋 Taiwan.md…"
            class="search-input"
            aria-label="搜尋 Taiwan.md"
            data-i18n-placeholder="search.placeholder"
          />
          <button
            type="submit"
            class="btn btn-primary"
            data-i18n-text="search.label">搜尋</button
          >
        </form>
      </div>

      <div class="report-section">
        <p class="report-title" data-i18n="bug.title">🐛 這是個 Bug 嗎？</p>
        <p class="report-desc" data-i18n="bug.desc">
          如果你覺得這個頁面應該存在，歡迎回報讓我們修復：
        </p>
        <a
          href={`https://github.com/frank890417/taiwan-md/issues/new?template=broken-link.yml&title=404:+${encodeURIComponent('[填入你看到的網址]')}&labels=bug,broken-link`}
          class="btn btn-report"
          target="_blank"
          rel="noopener"
          id="report-link"
          data-i18n-text="bug.btn"
        >
          📋 回報失效連結 (GitHub Issue)
        </a>
      </div>

      <div class="explore-section">
        <p data-i18n="explore">或者探索這些主題：</p>
        <div class="category-chips" id="category-chips">
          {
            categories.map((cat) => (
              <a
                href={`/${cat}`}
                data-category={cat}
                data-i18n-text={`cat.${cat}`}
              >
                {i18n['zh-TW'][`cat.${cat}`]}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Untranslated article notice (hidden by default) -->
    <div
      class="error-content"
      id="notfound-untranslated"
      style="display: none;"
    >
      <h1 class="error-code" style="opacity: 0.08;">📝</h1>
      <p
        class="error-title"
        id="untranslated-title"
        data-i18n="untranslated.title"
      >
        這篇文章尚未翻譯
      </p>
      <p class="error-desc" id="untranslated-desc"></p>

      <div class="lang-links" id="lang-links">
        <p data-i18n="untranslated.view">查看其他語言版本：</p>
        <div class="lang-chips" id="lang-chips"></div>
      </div>

      <div class="contribute-section">
        <p id="contribute-text" data-i18n="untranslated.contribute">
          想幫忙翻譯？
        </p>
        <a
          href="https://github.com/frank890417/taiwan-md/blob/main/CONTRIBUTING.md"
          class="btn btn-primary"
          target="_blank"
          rel="noopener"
        >
          CONTRIBUTING.md
        </a>
      </div>

      <div class="error-actions" style="margin-top: 2rem;">
        <a
          href="/"
          class="btn btn-secondary"
          id="back-link-2"
          data-i18n-text="back">← 回首頁</a
        >
      </div>

      <div class="explore-section" style="margin-top: 2rem;">
        <p data-i18n="explore">或者探索這些主題：</p>
        <div class="category-chips" id="category-chips-2">
          {
            categories.map((cat) => (
              <a
                href={`/${cat}`}
                data-category={cat}
                data-i18n-text={`cat.${cat}`}
              >
                {i18n['zh-TW'][`cat.${cat}`]}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ articleIndex, i18n }}>
  (() => {
    const main = document.querySelector('.error-page');
    const pathname = window.location.pathname;

    // Detect language from URL
    let lang = 'zh-TW';
    let pathWithoutLang = pathname;
    for (const prefix of ['en', 'ja', 'ko']) {
      if (pathname.startsWith(`/${prefix}/`) || pathname === `/${prefix}`) {
        lang = prefix;
        pathWithoutLang = pathname.slice(prefix.length + 1) || '/';
        break;
      }
    }

    const strings = i18n[lang] || i18n['zh-TW'];
    const langPrefix = lang === 'zh-TW' ? '' : `/${lang}`;
    const homeHref = langPrefix || '/';

    // Localize all i18n elements
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n');
      if (strings[key]) el.textContent = strings[key];
    });
    document.querySelectorAll('[data-i18n-text]').forEach((el) => {
      const key = el.getAttribute('data-i18n-text');
      if (strings[key]) el.textContent = strings[key];
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (strings[key])
        el.setAttribute(
          'placeholder',
          key === 'search.placeholder' ? strings[key] : strings[key],
        );
    });

    // Update home links
    document.querySelectorAll('#back-link, #back-link-2').forEach((el) => {
      el.setAttribute('href', homeHref);
    });

    // Update category chips with language prefix
    document
      .querySelectorAll('#category-chips a, #category-chips-2 a')
      .forEach((el) => {
        const cat = el.getAttribute('data-category');
        el.setAttribute('href', `${langPrefix}/${cat}`);
      });

    // Auto-fill bug report link
    const reportLink = document.getElementById('report-link');
    if (reportLink) {
      const href = reportLink.getAttribute('href');
      reportLink.setAttribute(
        'href',
        href.replace(
          encodeURIComponent('[填入你看到的網址]'),
          encodeURIComponent(pathname),
        ),
      );
    }

    // Fix Google search form
    const form = document.querySelector('.search-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        const inputs = form.querySelectorAll('input[name="q"]');
        if (inputs.length === 2) {
          const sitePrefix = inputs[0].value;
          const userQuery = inputs[1].value.trim();
          if (userQuery) {
            inputs[0].value = `${sitePrefix} ${userQuery}`;
            inputs[1].removeAttribute('name');
          }
        }
      });
    }

    // Smart detection: is this a known but untranslated article?
    if (lang !== 'zh-TW' && pathWithoutLang !== '/') {
      // Parse: /food/beef-noodle-soup → category=food, slug=beef-noodle-soup
      const parts = pathWithoutLang
        .replace(/^\//, '')
        .replace(/\/$/, '')
        .split('/');
      if (parts.length === 2) {
        const [category, slug] = parts;
        const key = `${category}/${decodeURIComponent(slug)}`;
        const article = articleIndex[key];

        if (article && !article.langs.includes(lang)) {
          // Article exists but not in this language!
          document.getElementById('notfound-generic').style.display = 'none';
          const untranslatedEl = document.getElementById(
            'notfound-untranslated',
          );
          untranslatedEl.style.display = 'block';

          // Build description
          const desc = document.getElementById('untranslated-desc');
          const titleDisplay =
            article.enTitle !== article.zhTitle
              ? `${article.zhTitle} (${article.enTitle})`
              : article.zhTitle;
          desc.textContent = `${strings['untranslated.desc.prefix']}${titleDisplay}${strings['untranslated.desc.suffix']}`;

          // Build language links
          const chipsContainer = document.getElementById('lang-chips');
          const langUrls = {
            'zh-TW': `/${category}/${encodeURIComponent(article.zhTitle)}`,
            en: `/en/${category}/${slug}`,
            ja: `/ja/${category}/${slug}`,
            ko: `/ko/${category}/${slug}`,
          };

          for (const availLang of article.langs) {
            const chip = document.createElement('a');
            chip.href = langUrls[availLang] || '#';
            chip.textContent = strings[`lang.${availLang}`] || availLang;
            chip.className = 'lang-chip';
            chipsContainer.appendChild(chip);
          }
        }
      }
    }

    // Reveal page (prevent FOUC)
    main.style.opacity = '1';
  })();
</script>

<style>
  .error-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem var(--space-page-x);
  }

  .error-content {
    max-width: 600px;
    text-align: center;
  }

  .error-code {
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 900;
    color: #1a1a2e;
    margin: 0;
    line-height: 1;
    opacity: 0.15;
  }

  .error-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0.5rem 0;
    font-family: var(--font-editorial);
  }

  .error-desc {
    color: #666;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .error-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-size: 0.95rem;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
  }

  .btn-primary {
    background: #1a1a2e;
    color: white;
  }
  .btn-primary:hover {
    background: #2d2d4a;
  }

  .btn-secondary {
    background: #f0f0f0;
    color: #333;
  }
  .btn-secondary:hover {
    background: #e0e0e0;
  }

  .search-section {
    margin-bottom: 2.5rem;
  }
  .search-section p {
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .search-form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }

  .search-input {
    padding: 0.5rem 1rem;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 0.95rem;
    width: 280px;
    outline: none;
    transition: border-color 0.2s;
  }
  .search-input:focus {
    border-color: #1a1a2e;
  }

  .report-section {
    background: #fef3c7;
    border: 1px solid #fcd34d;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
  }
  .report-title {
    font-weight: 700;
    margin: 0 0 0.4rem 0;
    font-size: 1rem;
  }
  .report-desc {
    color: #666;
    font-size: 0.88rem;
    margin: 0 0 1rem 0;
  }

  .btn-report {
    background: #f59e0b;
    color: white;
    font-size: 0.9rem;
  }
  .btn-report:hover {
    background: #d97706;
  }

  .explore-section p {
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .category-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }
  .category-chips a {
    padding: 0.35rem 0.75rem;
    background: #f5f5f5;
    border-radius: 20px;
    font-size: 0.85rem;
    text-decoration: none;
    color: #333;
    transition: all 0.2s;
  }
  .category-chips a:hover {
    background: #1a1a2e;
    color: white;
  }

  /* Untranslated-specific styles */
  .lang-links {
    margin: 1.5rem 0;
  }
  .lang-links p {
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }
  .lang-chips {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .lang-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background: #e8f5e9;
    border: 1px solid #a5d6a7;
    border-radius: 8px;
    font-size: 0.95rem;
    text-decoration: none;
    color: #2e7d32;
    font-weight: 600;
    transition: all 0.2s;
  }
  .lang-chip:hover {
    background: #c8e6c9;
    border-color: #66bb6a;
  }

  .contribute-section {
    background: #e3f2fd;
    border: 1px solid #90caf9;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-top: 1.5rem;
  }
  .contribute-section p {
    font-weight: 600;
    margin: 0 0 0.75rem 0;
    color: #1565c0;
  }

  @media (max-width: 640px) {
    .error-actions {
      flex-direction: column;
      align-items: center;
    }
    .search-form {
      flex-direction: column;
      align-items: center;
    }
    .search-input {
      width: 100%;
    }
  }
</style>
