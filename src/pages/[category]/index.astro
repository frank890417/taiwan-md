---
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';
import Layout from '../../layouts/Layout.astro';
import CategoryHero from '../../components/CategoryHero.astro';
import { marked } from 'marked';
import { categoryConfig, getCategoryConfig, type CategoryKey } from '../../utils/categoryConfig';

export async function getStaticPaths() {
  const categories = Object.keys(categoryConfig);
  const categoryMapping: Record<string, string> = {
    history: 'History',
    geography: 'Geography',
    culture: 'Culture',
    food: 'Food',
    art: 'Art',
    music: 'Music',
    technology: 'Technology',
    nature: 'Nature',
    people: 'People',
    society: 'Society',
    economy: 'Economy',
    lifestyle: 'Lifestyle',
  };

  const paths = [];

  for (const category of categories) {
    const folderName = categoryMapping[category];
    const articles = [];

    try {
      const zhFolderPath = resolve(process.cwd(), 'knowledge', folderName);
      const zhFiles = await readdir(zhFolderPath);
      const zhMarkdownFiles = zhFiles.filter((file) => file.endsWith('.md') && !file.startsWith('_'));

      for (const file of zhMarkdownFiles) {
        const filePath = join(zhFolderPath, file);
        const fileContent = await readFile(filePath, 'utf-8');
        const { data: frontmatter } = matter(fileContent);
        const slug = basename(file, '.md');

        articles.push({
          slug,
          title: frontmatter.title || slug,
          description: frontmatter.description || '',
          status: frontmatter.status || '',
          readingTime: frontmatter.readingTime || null,
          date: frontmatter.date || null,
          featured: frontmatter.featured || false,
          lang: 'zh-TW',
        });
      }
    } catch {}

    let hubContent = '';
    try {
      const hubFolder = resolve(process.cwd(), 'knowledge', folderName);
      const hubFiles = await readdir(hubFolder);
      const hubFile = hubFiles.find((f) => f.startsWith('_') && f.includes('Hub'));
      if (hubFile) {
        const hubPath = join(hubFolder, hubFile);
        const hubRaw = await readFile(hubPath, 'utf-8');
        const { content } = matter(hubRaw);
        hubContent = content.replace(/^#\s+.+\n/, '').trim();
      }
    } catch {}

    paths.push({
      params: { category },
      props: {
        categoryInfo: categoryConfig[category as CategoryKey],
        category,
        hubContent,
        articles: articles.sort((a, b) => {
          if (a.featured && !b.featured) return -1;
          if (!a.featured && b.featured) return 1;
          return a.title.localeCompare(b.title);
        }),
      },
    });
  }

  return paths;
}

const { categoryInfo, category, hubContent, articles } = Astro.props;

// Load economic data for economy category
let taiexData: any[] = [];
let cpiData: any[] = [];
let salaryData: any[] = [];
let housingData: any[] = [];
if (category === 'economy') {
  const [taiexJson, cpiJson, salaryJson, housingJson] = await Promise.all([
    import('../../data/taiex-yearly.json'),
    import('../../data/taiwan-cpi.json'),
    import('../../data/taiwan-salary.json'),
    import('../../data/taiwan-housing.json'),
  ]);
  taiexData = taiexJson.data;
  cpiData = cpiJson.data;
  salaryData = salaryJson.data;
  housingData = housingJson.data;
}

function resolveWikilinks(md: string, currentCategory: string) {
  if (!md) return md;
  return md.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, target, display) => {
    const label = display || target;
    if (target.startsWith('_')) {
      const catName = target.replace(/^_/, '').replace(/ Hub$/, '').toLowerCase();
      return `[${label}](/${catName})`;
    }
    const matchArticle = articles.find((a: any) => a.title === target || a.slug === target || a.slug === encodeURIComponent(target));
    if (matchArticle) {
      return `[${label}](/${currentCategory}/${matchArticle.slug})`;
    }
    return `**${label}**`;
  });
}

const resolvedContent = hubContent ? resolveWikilinks(hubContent, category) : '';

// Broken image fallback for hub pages
const hubRenderer = new marked.Renderer();
hubRenderer.image = ({ href, title, text }) => {
  const titleAttr = title ? ` title="${title}"` : '';
  const altText = text || '';
  return `<img src="${href}" alt="${altText}"${titleAttr} loading="lazy" onerror="this.onerror=null;this.classList.add('img-broken')" />`;
};
const hubHtml = resolvedContent ? marked.parse(resolvedContent, { renderer: hubRenderer }) : '';

// Split hub HTML into sections at <h2>boundaries for chart injection (economy only)
const isEconomy = category === 'economy';
type HubSection = { html: string; chartAfter?: string };
let hubSections: HubSection[] = [];
if (isEconomy && hubHtml) {
  const parts = (hubHtml as string).split(/(?=<h2>)/);
  hubSections = parts.map(part => {
    let chartAfter: string | undefined;
    if (part.includes('從零到英雄')) chartAfter = 'cpi';
    else if (part.includes('矽島的誕生')) chartAfter = 'taiex';
    else if (part.includes('服務經濟')) chartAfter = 'salary';
    else if (part.includes('面向未來')) chartAfter = 'housing';
    return { html: part, chartAfter };
  });
}

// 其他分類（跨分類導航用）
const otherCategories = Object.keys(categoryConfig)
  .filter(cat => cat !== category)
  .slice(0, 5) // 只顯示5個
  .map(cat => ({
    key: cat,
    ...categoryConfig[cat as CategoryKey]
  }));
---

<Layout
  title={`${categoryInfo.name} - Taiwan.md`}
  description={`${categoryInfo.description} - 台灣知識庫`}
>
  <main class="category-page">
    <CategoryHero
      name={categoryInfo.name}
      description={categoryInfo.description}
      coverUrl={categoryInfo.cover}
      gradient={categoryInfo.gradient}
      articleCount={articles.length}
      homeHref="/"
      homeLabel="首頁"
      countSuffix="篇文章"
    />

    <div class="container">
      <!-- Hub Content (curated overview) -->
      {hubHtml && !isEconomy && (
        <section class="hub-content">
          <div class="hub-prose" set:html={hubHtml} />
        </section>
      )}

      {isEconomy && hubSections.length > 0 && (
        <section class="hub-content">
          <div class="hub-prose">
            {hubSections.map((section) => (
              <Fragment>
                <div set:html={section.html} />
                {section.chartAfter && (
                  <div class="econ-chart-wrapper" data-chart={section.chartAfter}>
                    <div class="econ-chart-container">
                      <div class="econ-chart-header">
                        <h4 class="econ-chart-title">
                          {section.chartAfter === 'taiex' && ' 歷年台灣加權股價指數 (TAIEX)'}
                          {section.chartAfter === 'cpi' && ' 歷年消費者物價指數 (CPI)'}
                          {section.chartAfter === 'salary' && ' 歷年每月經常性薪資'}
                          {section.chartAfter === 'housing' && ' 信義房價指數'}
                        </h4>
                        <span class="econ-chart-source">
                          {section.chartAfter === 'taiex' && '資料來源：臺灣證券交易所'}
                          {section.chartAfter === 'cpi' && '資料來源：行政院主計總處'}
                          {section.chartAfter === 'salary' && '資料來源：行政院主計總處'}
                          {section.chartAfter === 'housing' && '資料來源：信義房屋'}
                        </span>
                      </div>
                      <div class="econ-chart-svg-wrap">
                        <svg class="econ-chart-svg" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid meet">
                        </svg>
                        <div class="econ-chart-tooltip"></div>
                      </div>
                    </div>
                  </div>
                )}
              </Fragment>
            ))}
          </div>
        </section>
      )}

      <!-- Articles Section -->
      <h2 class="articles-heading">延伸閱讀</h2>
      {articles.length > 0 ? (
        <section class="articles-section">
          <div class="articles-grid">
            {articles.map((article, index) => (
              <article class={`article-card ${index === 0 && article.featured ? 'featured-card' : ''}`}>
                <a href={`/${category}/${article.slug}`} class="card-link">
                  <div class="card-cover" style={categoryInfo.cover ? `background-image: url('${categoryInfo.cover}');` : `background: ${categoryInfo.gradient};`}></div>

                  <div class="card-body">
                    <div class="card-header">
                      <div class="article-meta">
                        {article.status && (
                          <span class="status-tag">{article.status}</span>
                        )}
                      </div>
                      {article.featured && (
                        <div class="featured-badge">精選</div>
                      )}
                    </div>

                    <h3 class="article-title">{article.title}</h3>
                    <p class="article-excerpt">{article.description}</p>

                    <div class="card-footer">
                      {article.readingTime && (
                        <span class="reading-time">{article.readingTime} 分鐘</span>
                      )}
                      <span class="read-more">閱讀全文 →</span>
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>
      ) : (
        <section class="coming-soon">
          <div class="coming-soon-content">
            <h2>內容準備中</h2>
            <p>這個分類的文章正在努力製作中，敬請期待！</p>
            <p class="category-desc">未來這裡將會有：{categoryInfo.description}</p>

            <div class="action-buttons">
              <a href="/" class="btn-primary">返回首頁</a>
              <a href="https://github.com/frank890417/taiwan-md" target="_blank" class="btn-secondary">
                參與貢獻
              </a>
            </div>
          </div>
        </section>
      )}

      <!-- 探索其他面向 -->
      <section class="explore-more">
        <h2 class="explore-title">探索台灣其他面向</h2>
        <div class="categories-grid">
          {otherCategories.map(cat => (
            <a href={`/${cat.key}`} class="category-card" style={`border-color: ${cat.color}; color: ${cat.color};`}>
              <div class="category-card-name">{cat.name}</div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>

<style define:vars={{ categoryColor: categoryInfo.color, categoryColorLight: categoryInfo.colorLight }}>
  .category-page {
    min-height: 100vh;
  }

  /* Container */
  .container {
    max-width: var(--container-page);
    margin: 0 auto;
