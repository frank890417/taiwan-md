---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import CoverStory from '../components/home/CoverStory.astro';
import RandomDiscovery from '../components/home/RandomDiscovery.astro';
import ReadingPath from '../components/ReadingPath.astro';
import FeatureCards from '../components/FeatureCards.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import LanguageStatement from '../components/home/LanguageStatement.astro';
import RecentUpdates from '../components/home/RecentUpdates.astro';
import NewsletterSection from '../components/home/NewsletterSection.astro';
import CommunityFeedback from '../components/home/CommunityFeedback.astro';
import ContributeSection from '../components/home/ContributeSection.astro';
import ProticoScript from '../components/ProticoScript.astro';
import { fetchRecentCommits } from '../lib/commits';
import { feedbacks } from '../data/feedbacks';
import { useTranslations, getLangFromUrl } from '../i18n/utils';
import matter from 'gray-matter';
import { readFileSync, readdirSync } from 'node:fs';
import { resolve, join, basename } from 'node:path';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const recentCommits = await fetchRecentCommits();

// ── Exhibition: scan A-grade articles for pick cards ──
interface PickArticle {
  title: string;
  href: string;
  footnotes: number;
  readingTime: number;
  description: string;
  featured?: boolean;
}

const categoryFolders: Record<string, string> = {
  history: 'History',
  geography: 'Geography',
  culture: 'Culture',
  food: 'Food',
  art: 'Art',
  music: 'Music',
  technology: 'Technology',
  nature: 'Nature',
  people: 'People',
  society: 'Society',
  economy: 'Economy',
  lifestyle: 'Lifestyle',
};

const topPicks: Record<string, PickArticle[]> = {};

for (const [slug, folder] of Object.entries(categoryFolders)) {
  const dir = resolve(process.cwd(), 'knowledge', folder);
  const picks: PickArticle[] = [];
  try {
    const files = readdirSync(dir).filter(
      (f) => f.endsWith('.md') && !f.startsWith('_'),
    );
    for (const file of files) {
      const raw = readFileSync(join(dir, file), 'utf-8');
      const { data } = matter(raw);
      const fnCount = (raw.match(/^\[\^\d+\]:/gm) || []).length;
      // Two-tier threshold: featured articles at ≥8fn, others at ≥15fn
      const threshold = data.featured ? 8 : 15;
      if (fnCount >= threshold) {
        picks.push({
          title: data.title || basename(file, '.md'),
          href: `/${slug}/${encodeURIComponent(basename(file, '.md'))}`,
          footnotes: fnCount,
          readingTime: data.readingTime || 10,
          description: data.description || '',
          featured: data.featured || false,
        });
      }
    }
  } catch {}
  // Featured first, then by footnotes
  topPicks[slug] = picks
    .sort((a, b) => {
      if (a.featured !== b.featured) return a.featured ? -1 : 1;
      return b.footnotes - a.footnotes;
    })
    .slice(0, 3);
}

// ── Hall-level dedup: remove near-duplicate titles across categories in same hall ──
const hallGroups: Record<string, string[]> = {
  hall1: ['geography', 'nature', 'lifestyle'],
  hall2: ['history', 'culture', 'society'],
  hall3: ['people', 'art', 'music'],
  hall4: ['technology', 'economy', 'food'],
};

for (const cats of Object.values(hallGroups)) {
  const seen = new Set<string>();
  for (const cat of cats) {
    topPicks[cat] = (topPicks[cat] || [])
      .filter((p) => {
        const prefix = p.title.slice(0, 4);
        if (seen.has(prefix)) return false;
        seen.add(prefix);
        return true;
      })
      .slice(0, 2); // max 2 per category within a hall
  }
}

// ── Dynamic reading path: pick top A-grade from different categories ──
const usedCategories = new Set<string>();
const readingCandidates = Object.entries(topPicks)
  .flatMap(([cat, arts]) => arts.slice(0, 1).map((a) => ({ ...a, cat })))
  .sort((a, b) => b.footnotes - a.footnotes);

const readingPathSteps = readingCandidates
  .filter((a) => {
    if (usedCategories.has(a.cat)) return false;
    usedCategories.add(a.cat);
    return true;
  })
  .slice(0, 5)
  .map((a) => ({
    href: a.href,
    title: a.title,
    description:
      a.description.length > 60
        ? a.description.slice(0, 57) + '...'
        : a.description,
    time: `${a.readingTime} min`,
  }));

const totalTime = readingPathSteps.reduce(
  (sum, s) => sum + parseInt(s.time),
  0,
);

const readingPathFooterItems = [
  { icon: '⏱️', label: `總計 ${totalTime} 分鐘` },
  { icon: '🎯', label: `跨越 ${readingPathSteps.length} 大領域` },
  { icon: '🌟', label: '完整認識台灣' },
];
---

<Layout
  title="開源台灣知識庫"
  description="開源、AI-friendly 的台灣完整知識庫。660+ 頁深度內容涵蓋歷史、文化、美食、音樂、科技等 12 大主題，由社群共同編撰，讓全世界認識真正的台灣。"
>
  <HeroSection />

  <CoverStory />

  <RandomDiscovery />

  <ReadingPath
    title="📖 不知道從哪開始？"
    subtitle="用這 5 篇文章，在 30 分鐘內認識真正的台灣"
    steps={readingPathSteps}
    footerItems={readingPathFooterItems}
    continueHref="#categories"
    continueLabel="繼續探索更多主題 →"
  />

  <FeatureCards
    lang="zh-TW"
    sectionTitle="為什麼需要 Taiwan.md？"
    cards={[
      {
        icon: '🎯',
        title: '策展式觀點',
        description: '精心策展的深度敘事，不是百科全書式羅列',
      },
      {
        icon: '🤖',
        title: 'AI-Friendly 設計',
        description: '結構化內容，讓AI也能理解台灣的複雜性',
      },
      {
        icon: '🌍',
        title: '雙語國際視野',
        description: '從在地觀點出發，用國際語言說台灣故事',
      },
      {
        icon: '📚',
        title: '完整多面向',
        description: '涵蓋12+領域，呈現台灣的立體完整面貌',
      },
    ]}
  >
    <div class="features-cta">
      <a href="/graph" class="feature-btn">🔗 知識圖譜 — 探索文章之間的連結</a>
      <a
        href="https://github.com/frank890417/taiwan-md/tree/main/knowledge"
        target="_blank"
        rel="noopener noreferrer"
        class="feature-btn secondary">📂 瀏覽 SSOT 原始資料 ↗</a
      >
    </div>
  </FeatureCards>

  <section class="mini-graph-section">
    <a href="/graph" class="mini-graph-link">
      <div class="mini-graph-text">
        <h3>🕸️ 知識圖譜</h3>
        <p>每篇文章都不是孤島——點擊探索台灣知識的連結網絡</p>
      </div>
      <div id="mini-graph" class="mini-graph-container"></div>
    </a>
  </section>

  <!-- ===== EXHIBITION HALLS ===== -->
  <section class="exhibition" id="categories">
    <div class="exhibition-header">
      <h2 class="section-title">{t('home.categories.heading')}</h2>
    </div>

    <div class="exhibition-halls">
      {/* ── 展廳一：這座島長什麼樣 ── */}
      <div class="exhibition-hall">
        <div class="hall-divider">
          <div class="hall-line"></div>
          <span class="hall-label">壹 — 這座島長什麼樣</span>
          <div class="hall-line"></div>
        </div>
        <div class="hall-body">
          <p>
            這座島嶼只有 36,000 平方公里，卻裝進了整個世界的縮影。 從 3,952
            公尺的玉山之巔到太平洋的深海溝壑，
            <a href="/geography" class="topic-pill">🗺️ 這裡的地理</a
            >本身就是一場造山運動的現場直播——
            板塊擠壓、火山噴發、斷層錯動，四百萬年來不停歇的地質交響曲，
            造就了這座世界上最年輕也最動盪的美麗島嶼。
          </p>
          {
            topPicks.geography && topPicks.geography.length > 0 && (
              <div class="hall-picks">
                {topPicks.geography.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            蝴蝶王國不是浪漫的比喻，而是生態現實。在這個比荷蘭還小的島嶼上，
            擠進了超過五萬九千種生物——佔全球物種數量的百分之二點五。
            <a href="/nature" class="topic-pill">🌿 台灣的自然</a
            >是一部立體的演化史書：
            從熱帶雨林到高山寒原，從珊瑚礁到黑潮，物種在此演化、分化、共存。
            但工業發展的代價也寫在山川裡，環保與開發的拉扯仍在進行。
          </p>
          {
            topPicks.nature && topPicks.nature.length > 0 && (
              <div class="hall-picks">
                {topPicks.nature.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            台灣人的<a href="/lifestyle" class="topic-pill">🏠 生活方式</a
            >是便利與人情的混合體。
            便利商店的密度世界第一，夜市的溫度卻是獨一無二。 24
            小時不打烊的城市節奏裡，依然保留著鄰里的問候與照顧。
            在全球化的洪流中，台灣人如何保持自己的生活哲學？
            答案或許就在那一句「你吃飽了嗎？」的日常問候裡。
          </p>
          {
            topPicks.lifestyle && topPicks.lifestyle.length > 0 && (
              <div class="hall-picks">
                {topPicks.lifestyle.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>

      {/* ── 展廳二：這座島怎麼來的 ── */}
      <div class="exhibition-hall">
        <div class="hall-divider">
          <div class="hall-line"></div>
          <span class="hall-label">貳 — 這座島怎麼來的</span>
          <div class="hall-line"></div>
        </div>
        <div class="hall-body">
          <p>
            四百年前，荷蘭人在台南築起了熱蘭遮城。此後的每一個統治者——
            鄭氏、清帝國、日本、國民黨——都在這座島上刻下了自己的銘文。
            但真正讓台灣成為台灣的，是那段從威權到民主的<a
              href="/history"
              class="topic-pill">📜 漫長覺醒</a
            >。 從二二八的血淚到解嚴的歡呼，從美麗島到太陽花，
            每一次的痛苦與反抗，都讓這座島的靈魂更加清晰。
          </p>
          {
            topPicks.history && topPicks.history.length > 0 && (
              <div class="hall-picks">
                {topPicks.history.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            這片土地上流淌著多重血液。原住民族在此安居了六千年，
            十七世紀後陸續到來的閩南人、客家人，戰後從大陸各省遷徙而來的外省族群，
            近年的新住民與移工，每一群人都帶來了自己的語言、信仰與記憶。
            <a href="/culture" class="topic-pill">🎭 台灣的文化</a
            >不是熔爐，而是拼圖——
            每一塊都保持著自己的顏色與形狀，拼湊出一幅前所未有的圖像。
          </p>
          {
            topPicks.culture && topPicks.culture.length > 0 && (
              <div class="hall-picks">
                {topPicks.culture.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            <a href="/society" class="topic-pill">⚖️ 台灣社會</a
            >的關鍵字是「多元」與「包容」。
            從亞洲第一個同性婚姻合法化，到轉型正義的持續推動，
            從核四公投到年金改革，台灣人正在學習如何在分歧中對話，
            在衝突中尋找共識。這是民主的練習場，也是未來的實驗室。
          </p>
          {
            topPicks.society && topPicks.society.length > 0 && (
              <div class="hall-picks">
                {topPicks.society.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>

      {/* ── 展廳三：這座島的人在做什麼 ── */}
      <div class="exhibition-hall">
        <div class="hall-divider">
          <div class="hall-line"></div>
          <span class="hall-label">參 — 這座島的人在做什麼</span>
          <div class="hall-line"></div>
        </div>
        <div class="hall-body">
          <p>
            從賴和、楊逵到白先勇、朱天心，從霧峰林家到辜振甫家族，
            <a href="/people" class="topic-pill">👥 台灣的人物</a>是時代的縮影。
            他們不只是個人的傳記，更是這座島嶼如何在夾縫中求生存、
            在困頓中找希望的集體記憶。每一個故事背後，
            都是大時代下小人物的堅韌與選擇。
          </p>
          {
            topPicks.people && topPicks.people.length > 0 && (
              <div class="hall-picks">
                {topPicks.people.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            從廟會的八家將到當代藝術的威尼斯雙年展，
            <a href="/art" class="topic-pill">🎨 台灣的藝術</a
            >是傳統與創新的對話。 交趾陶與數位裝置、傳統戲曲與實驗劇場、
            原住民圖騰與當代繪畫——藝術家們不斷在問：
            我們如何用創作回應這個時代？如何在全球化中保持在地性？
          </p>
          {
            topPicks.art && topPicks.art.length > 0 && (
              <div class="hall-picks">
                {topPicks.art.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            從原住民的古調到鄧雨賢的〈望春風〉，從校園民歌到金曲獎，
            <a href="/music" class="topic-pill">🎵 台灣的聲音</a>是島嶼的心跳。
            音樂跨越了族群、語言、世代的界線，成為最能凝聚共同記憶的載體。
            無論是五月天在小巨蛋的吶喊，還是原住民在部落裡的古謠，
            都在述說著同一個故事：我們是誰，我們來自哪裡。
          </p>
          {
            topPicks.music && topPicks.music.length > 0 && (
              <div class="hall-picks">
                {topPicks.music.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>

      {/* ── 展廳四：這座島往哪裡去 ── */}
      <div class="exhibition-hall">
        <div class="hall-divider">
          <div class="hall-line"></div>
          <span class="hall-label">肆 — 這座島往哪裡去</span>
          <div class="hall-line"></div>
        </div>
        <div class="hall-body">
          <p>
            台積電的晶圓不只是矽片，而是台灣在全球科技版圖上的定位證明。
            <a href="/technology" class="topic-pill">💻 這座科技島</a
            >從代工製造走向創新研發，
            從硬體優勢邁向軟體突破。但科技發展也帶來了挑戰： 數位落差、AI
            取代、資安威脅——台灣如何在科技浪潮中既衝浪又不被淹沒？
          </p>
          {
            topPicks.technology && topPicks.technology.length > 0 && (
              <div class="hall-picks">
                {topPicks.technology.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
            從亞洲四小龍到半導體帝國，<a href="/economy" class="topic-pill"
              >📈 台灣的經濟奇蹟</a
            >
            是小國大戰略的典型案例。但奇蹟背後是無數個加班的夜晚、 斤斤計較的成本控制、永不停歇的效率追求。
            如今面對中美貿易戰、全球供應鏈重組，台灣如何繼續寫下經濟傳奇？
          </p>
          {
            topPicks.economy && topPicks.economy.length > 0 && (
              <div class="hall-picks">
                {topPicks.economy.map((a) => (
                  <a href={a.href} class="pick-card">
                    <span class="pick-head">
                      <span class="pick-title">{a.title}</span>
                      <span class="pick-fn">{a.footnotes} 引用</span>
                    </span>
                    {a.description && (
                      <span class="pick-desc">
                        {a.description.length > 80
                          ? a.description.slice(0, 77) + '...'
                          : a.description}
                      </span>
                    )}
                  </a>
                ))}
              </div>
            )
          }

          <p>
