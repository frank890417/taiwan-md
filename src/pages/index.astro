<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline define:vars={{ randomArticlesData }}>
  document.addEventListener('DOMContentLoaded', function() {
    // Random discovery
    var randomBtn = document.getElementById('random-discovery-btn');
    var articles = [];
    try { articles = JSON.parse(randomArticlesData); } catch(e) {}
    
    if (randomBtn && articles.length > 0) {
      var shuffled = articles.slice();
      for (var i = shuffled.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = shuffled[i]; shuffled[i] = shuffled[j]; shuffled[j] = tmp;
      }
      var currentIndex = 0;

      randomBtn.addEventListener('click', function() {
        if (currentIndex >= shuffled.length) {
          currentIndex = 0;
          for (var i = shuffled.length - 1; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var tmp = shuffled[i]; shuffled[i] = shuffled[j]; shuffled[j] = tmp;
          }
        }
        var article = shuffled[currentIndex++];
        var textEl = randomBtn.querySelector('.random-text');
        var subtitleEl = randomBtn.querySelector('.random-subtitle');
        randomBtn.style.pointerEvents = 'none';
        var ticks = 0;
        var interval = setInterval(function() {
          var preview = shuffled[Math.floor(Math.random() * shuffled.length)];
          textEl.textContent = preview.title;
          subtitleEl.textContent = preview.category;
          ticks++;
          if (ticks >= 8) {
            clearInterval(interval);
            textEl.textContent = article.title;
            subtitleEl.textContent = article.category;
            setTimeout(function() { window.location.href = article.url; }, 400);
          }
        }, 80);
      });
    }

    // Newsletter form
    var form = document.getElementById('newsletter-form');
    if (form) {
      form.addEventListener('submit', function() {
        setTimeout(function() {
          document.getElementById('newsletter-success').classList.remove('hidden');
        }, 500);
      });
    }

    // Mini knowledge graph
    var container = document.getElementById('mini-graph');
    if (container && typeof d3 !== 'undefined') {
      var categories = [
        { id: 'history', name: '歷史', color: '#C17D5E' },
        { id: 'geography', name: '地理', color: '#006D77' },
        { id: 'culture', name: '文化', color: '#7c3aed' },
        { id: 'food', name: '美食', color: '#ea580c' },
        { id: 'art', name: '藝術', color: '#db2777' },
        { id: 'music', name: '音樂', color: '#4f46e5' },
        { id: 'technology', name: '科技', color: '#006D77' },
        { id: 'nature', name: '自然', color: '#16a34a' },
        { id: 'people', name: '人物', color: '#C17D5E' },
        { id: 'society', name: '社會', color: '#64748b' },
        { id: 'economy', name: '經濟', color: '#0d9488' },
        { id: 'lifestyle', name: '生活', color: '#f97316' },
      ];
      var nodes = [{ id: 'taiwan', name: 'Taiwan.md', size: 18, color: '#1A3C34', group: 'core' }];
      categories.forEach(function(c) { nodes.push({ id: c.id, name: c.name, size: 12, color: c.color, group: 'category' }); });
      var edges = categories.map(function(c) { return { source: 'taiwan', target: c.id }; });
      [['history','people'],['history','society'],['culture','art'],['culture','music'],['food','lifestyle'],['technology','economy'],['nature','geography'],['people','art'],['society','economy'],['music','culture'],['lifestyle','food'],['geography','nature']].forEach(function(pair) { edges.push({ source: pair[0], target: pair[1] }); });

      var width = container.clientWidth;
      var height = 300;
      var svg = d3.select('#mini-graph').append('svg').attr('viewBox', '0 0 '+width+' '+height).attr('preserveAspectRatio', 'xMidYMid meet');
      var simulation = d3.forceSimulation(nodes)
        .force('link', d3.forceLink(edges).id(function(d){return d.id}).distance(60))
        .force('charge', d3.forceManyBody().strength(-120))
        .force('center', d3.forceCenter(width/2, height/2))
        .force('collision', d3.forceCollide().radius(function(d){return d.size + 8}));
      var link = svg.append('g').selectAll('line').data(edges).enter().append('line')
        .attr('stroke', '#E5E7EB').attr('stroke-width', 1);
      var node = svg.append('g').selectAll('g').data(nodes).enter().append('g');
      node.append('circle').attr('r', function(d){return d.size}).attr('fill', function(d){return d.color}).attr('opacity', 0.9);
      node.append('text').text(function(d){return d.name}).attr('text-anchor','middle').attr('dy','0.35em')
        .attr('fill','white').attr('font-size', function(d){return d.group==='core'?'7px':'6px'}).attr('font-weight','600');
      simulation.on('tick', function() {
        link.attr('x1',function(d){return d.source.x}).attr('y1',function(d){return d.source.y})
            .attr('x2',function(d){return d.target.x}).attr('y2',function(d){return d.target.y});
        node.attr('transform', function(d){return 'translate('+d.x+','+d.y+')'});
      });
    }
  });
</script>
