---
import Layout from '../layouts/Layout.astro';
---

<Layout title="台灣地圖 Map" description="以地圖視角探索 Taiwan.md 的內容脈絡">
  <div class="map-page">

    <!-- ── Hero ── -->
    <section class="map-hero">
      <!-- decorative faint island outline -->
      <div class="hero-deco" aria-hidden="true">
        <svg viewBox="0 0 260 600" fill="none" xmlns="http://www.w3.org/2000/svg" class="deco-island">
          <path d="M130 20 C155 20,172 38,174 65 C176 88,172 112,170 138
                   C168 164,166 190,163 216 C160 242,157 268,154 294
                   C151 320,148 346,143 372 C138 398,130 424,120 444
                   C110 464,96 476,80 478 C64 480,50 474,40 464
                   C30 454,22 438,18 418 C14 398,14 374,18 350
                   C22 326,28 302,30 278 C32 254,28 230,32 206
                   C36 182,44 158,54 136 C64 114,76 94,92 76
                   C108 58,120 24,130 20 Z"
                stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 6"/>
        </svg>
      </div>

      <div class="hero-inner">
        <p class="hero-kicker">Map View · 地圖探索</p>
        <h1>
          <span class="title-zh">台灣地圖</span>
          <span class="title-en">Interactive Map</span>
        </h1>
        <p class="hero-subtitle">
          用地理視角漫遊台灣的文化積澱、自然奇景、歷史脈絡與美食地景
        </p>
        <div class="hero-meta">
          <span class="meta-pill">18 個知識節點</span>
          <span class="meta-sep">·</span>
          <span class="meta-pill">9 大分類</span>
          <span class="meta-sep">·</span>
          <span class="meta-pill">5 個區域</span>
        </div>
      </div>
    </section>

    <!-- ── Controls ── -->
    <section class="map-controls">
      <div class="controls-inner">
        <div class="filter-group">
          <p class="filter-label">區域篩選</p>
          <div class="filter-pills" id="regionFilters">
            <button class="pill active" data-filter="all">全部</button>
            <button class="pill" data-filter="north">北部</button>
            <button class="pill" data-filter="central">中部</button>
            <button class="pill" data-filter="south">南部</button>
            <button class="pill" data-filter="east">東部</button>
            <button class="pill" data-filter="islands">離島</button>
          </div>
        </div>

        <div class="filter-divider" aria-hidden="true"></div>

        <div class="filter-group">
          <p class="filter-label">分類篩選</p>
          <div class="filter-pills" id="categoryFilters">
            <button class="pill active" data-filter="all">全部</button>
            <button class="pill" data-filter="food">美食</button>
            <button class="pill" data-filter="history">歷史</button>
            <button class="pill" data-filter="nature">自然</button>
            <button class="pill" data-filter="culture">文化</button>
            <button class="pill" data-filter="technology">科技</button>
            <button class="pill" data-filter="economy">經濟</button>
            <button class="pill" data-filter="lifestyle">生活</button>
            <button class="pill" data-filter="art">藝術</button>
            <button class="pill" data-filter="geography">地理</button>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Map Body ── -->
    <section class="map-body">
      <div class="map-canvas-wrap">

        <!-- ambient ocean background -->
        <div class="ocean-bg" aria-hidden="true"></div>

        <div class="map-canvas" id="mapCanvas">
          <svg id="taiwanMap" viewBox="0 0 800 1000" class="taiwan-svg" role="img" aria-label="台灣知識地圖">
            <defs>
              <!-- Island land gradient — deep forest tones -->
              <linearGradient id="landGradient" x1="0%" y1="0%" x2="20%" y2="100%">
                <stop offset="0%"   stop-color="#2A5240"/>
                <stop offset="40%"  stop-color="#1E4534"/>
                <stop offset="100%" stop-color="#163829"/>
              </linearGradient>

              <!-- subtle ridge texture overlay -->
              <linearGradient id="ridgeOverlay" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%"   stop-color="#FFFFFF" stop-opacity="0.03"/>
                <stop offset="50%"  stop-color="#FFFFFF" stop-opacity="0.08"/>
                <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0.02"/>
              </linearGradient>

              <!-- glow filter for markers -->
              <filter id="markerGlow" x="-50%" y="-50%" width="200%" height="200%">
                <feGaussianBlur stdDeviation="3" result="blur"/>
                <feMerge>
                  <feMergeNode in="blur"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>

              <!-- Soft drop shadow for island -->
              <filter id="islandShadow" x="-20%" y="-10%" width="160%" height="140%">
                <feDropShadow dx="6" dy="12" stdDeviation="18" flood-color="#006D77" flood-opacity="0.25"/>
              </filter>

              <!-- Marker pulse ring -->
              <filter id="pulseGlow">
                <feGaussianBlur stdDeviation="2.5" result="blur"/>
                <feMerge>
                  <feMergeNode in="blur"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
            </defs>

            <!-- ── Taiwan main island ── -->
            <path
              d="M400 100
                 C450 100, 480 130, 485 180
                 C490 220, 485 260, 480 300
                 C475 340, 470 380, 465 420
                 C460 460, 455 500, 450 540
                 C445 580, 440 620, 435 660
                 C430 700, 425 740, 415 780
                 C405 820, 390 850, 370 870
                 C350 890, 320 895, 290 890
                 C260 885, 230 875, 210 860
                 C190 845, 175 825, 165 800
                 C155 775, 150 745, 155 710
                 C160 675, 170 640, 175 605
                 C180 570, 175 535, 180 500
                 C185 465, 195 430, 205 395
                 C215 360, 225 325, 235 290
                 C245 255, 255 220, 270 190
                 C285 160, 310 135, 340 125
                 C370 115, 390 105, 400 100 Z"
              fill="url(#landGradient)"
              stroke="#4A7860"
              stroke-width="1.5"
              filter="url(#islandShadow)"
              class="taiwan-mainland"
            />
            <!-- ridge highlight overlay -->
            <path
              d="M400 100
                 C450 100, 480 130, 485 180
                 C490 220, 485 260, 480 300
                 C475 340, 470 380, 465 420
                 C460 460, 455 500, 450 540
                 C445 580, 440 620, 435 660
                 C430 700, 425 740, 415 780
                 C405 820, 390 850, 370 870
                 C350 890, 320 895, 290 890
                 C260 885, 230 875, 210 860
                 C190 845, 175 825, 165 800
                 C155 775, 150 745, 155 710
                 C160 675, 170 640, 175 605
                 C180 570, 175 535, 180 500
                 C185 465, 195 430, 205 395
                 C215 360, 225 325, 235 290
                 C245 255, 255 220, 270 190
                 C285 160, 310 135, 340 125
                 C370 115, 390 105, 400 100 Z"
              fill="url(#ridgeOverlay)"
              pointer-events="none"
            />

            <!-- Central Mountain Range subtle line -->
            <path
              d="M400 110 C415 160,430 220,435 300 C438 360,432 440,420 520
                 C410 590,400 660,385 730 C375 780,360 840,345 875"
              fill="none" stroke="#6A9E7A" stroke-width="1" stroke-dasharray="3 5" opacity="0.4"
              pointer-events="none"
            />

            <!-- Penghu Islands -->
            <g class="island-group penghu-group">
              <ellipse cx="152" cy="450" rx="9" ry="6" fill="#1E4534" stroke="#4A7860" stroke-width="1"/>
              <ellipse cx="143" cy="462" rx="5" ry="4" fill="#1E4534" stroke="#4A7860" stroke-width="1"/>
              <ellipse cx="162" cy="458" rx="4" ry="3" fill="#1E4534" stroke="#4A7860" stroke-width="1"/>
            </g>

            <!-- Kinmen -->
            <g class="island-group kinmen-group">
              <ellipse cx="80" cy="400" rx="10" ry="5" fill="#1E4534" stroke="#4A7860" stroke-width="1"/>
            </g>

            <!-- Matsu -->
            <g class="island-group matsu-group">
              <ellipse cx="75" cy="320" rx="5" ry="4" fill="#1E4534" stroke="#4A7860" stroke-width="1"/>
            </g>

            <!-- ── Knowledge markers ── -->
            <g id="markers">
              <!-- North Region -->
              <g class="marker" data-region="north" data-category="food"
                 data-title="士林夜市" data-link="/food/夜市文化"
                 data-desc="台灣夜市文化的代表性據點，每晚匯聚數百攤位">
                <circle cx="350" cy="200" r="9" fill="#C17D5E" opacity="0.2"/>
                <circle cx="350" cy="200" r="6" fill="#C17D5E" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="north" data-category="nature"
                 data-title="陽明山國家公園" data-link="/nature/國家公園"
                 data-desc="台灣第一個國家公園，以火山地形聞名">
                <circle cx="330" cy="180" r="9" fill="#006D77" opacity="0.2"/>
                <circle cx="330" cy="180" r="6" fill="#006D77" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="north" data-category="economy"
                 data-title="台北101" data-link="/economy/經濟奇蹟"
                 data-desc="台灣經濟奇蹟的象徵，曾為世界第一高樓">
                <circle cx="370" cy="220" r="9" fill="#1A3C34" opacity="0.2"/>
                <circle cx="370" cy="220" r="6" fill="#1A3C34" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="north" data-category="history"
                 data-title="中正紀念堂" data-link="/history/戒嚴時期"
                 data-desc="見證台灣戒嚴時期的歷史建築，現為民主廣場">
                <circle cx="360" cy="236" r="9" fill="#8B6E5A" opacity="0.2"/>
                <circle cx="360" cy="236" r="6" fill="#8B6E5A" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="north" data-category="lifestyle"
                 data-title="西門町" data-link="/lifestyle/便利商店文化"
                 data-desc="台灣流行文化與便利商店文化發源地">
                <circle cx="345" cy="215" r="9" fill="#A0785A" opacity="0.2"/>
                <circle cx="345" cy="215" r="6" fill="#A0785A" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="north" data-category="technology"
                 data-title="新竹科學園區" data-link="/technology/半導體產業"
                 data-desc="台灣半導體產業重鎮，矽島核心">
                <circle cx="380" cy="255" r="9" fill="#006D77" opacity="0.2"/>
                <circle cx="380" cy="255" r="6" fill="#006D77" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <!-- Central Region -->
              <g class="marker" data-region="central" data-category="nature"
                 data-title="日月潭" data-link="/nature/國家公園"
                 data-desc="台灣最美麗的高山湖泊，四季風景各異">
                <circle cx="320" cy="420" r="9" fill="#006D77" opacity="0.2"/>
                <circle cx="320" cy="420" r="6" fill="#006D77" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="central" data-category="culture"
                 data-title="鹿港" data-link="/culture/廟宇文化與民間信仰"
                 data-desc="台灣廟宇文化的重要據點，保存完整的傳統街區">
                <circle cx="285" cy="390" r="9" fill="#5E4B8B" opacity="0.2"/>
                <circle cx="285" cy="390" r="6" fill="#5E4B8B" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="central" data-category="art"
                 data-title="台中國家歌劇院" data-link="/art/當代藝術"
                 data-desc="伊東豊雄設計的台灣當代藝術重要場域">
                <circle cx="310" cy="375" r="9" fill="#C17D5E" opacity="0.2"/>
                <circle cx="310" cy="375" r="6" fill="#C17D5E" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <!-- South Region -->
              <g class="marker" data-region="south" data-category="history"
                 data-title="台南府城" data-link="/history/荷西明鄭時期"
                 data-desc="台灣歷史文化古都，保存最多清代古蹟">
                <circle cx="300" cy="660" r="9" fill="#8B6E5A" opacity="0.2"/>
                <circle cx="300" cy="660" r="6" fill="#8B6E5A" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="south" data-category="economy"
                 data-title="高雄港" data-link="/economy/經濟奇蹟"
                 data-desc="台灣重要的海港經濟據點，亞洲重要樞紐港">
                <circle cx="310" cy="700" r="9" fill="#1A3C34" opacity="0.2"/>
                <circle cx="310" cy="700" r="6" fill="#1A3C34" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="south" data-category="nature"
                 data-title="墾丁國家公園" data-link="/nature/國家公園"
                 data-desc="台灣最南端的國家公園，熱帶海洋生態豐富">
                <circle cx="330" cy="820" r="9" fill="#006D77" opacity="0.2"/>
                <circle cx="330" cy="820" r="6" fill="#006D77" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="south" data-category="culture"
                 data-title="六堆客家文化" data-link="/culture/族群（閩南客家原住民外省新住民）"
                 data-desc="南台灣客家文化保存區，六大堆聚落文化">
                <circle cx="275" cy="735" r="9" fill="#5E4B8B" opacity="0.2"/>
                <circle cx="275" cy="735" r="6" fill="#5E4B8B" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <!-- East Region -->
              <g class="marker" data-region="east" data-category="nature"
                 data-title="太魯閣國家公園" data-link="/nature/國家公園"
                 data-desc="世界級的大理石峽谷地景，立霧溪切割而成">
                <circle cx="430" cy="340" r="9" fill="#006D77" opacity="0.2"/>
                <circle cx="430" cy="340" r="6" fill="#006D77" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="east" data-category="geography"
                 data-title="花東縱谷" data-link="/geography/台灣五大地形與地理結構"
                 data-desc="台灣最重要的板塊縫合帶，壯闊的縱谷地景">
                <circle cx="440" cy="460" r="9" fill="#2A6E48" opacity="0.2"/>
                <circle cx="440" cy="460" r="6" fill="#2A6E48" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="east" data-category="culture"
                 data-title="蘭嶼" data-link="/culture/原住民族文化"
                 data-desc="達悟族傳統文化保存地，拼板舟技藝傳承">
                <circle cx="490" cy="620" r="9" fill="#5E4B8B" opacity="0.2"/>
                <circle cx="490" cy="620" r="6" fill="#5E4B8B" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker" data-region="east" data-category="food"
                 data-title="池上" data-link="/food/台灣茶文化"
                 data-desc="台灣最優質稻米產區，花東縱谷豐饒之地">
                <circle cx="445" cy="500" r="9" fill="#C17D5E" opacity="0.2"/>
                <circle cx="445" cy="500" r="6" fill="#C17D5E" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <!-- Islands -->
              <g class="marker island-marker" data-region="islands" data-category="geography"
                 data-title="澎湖" data-link="/geography/離島與海洋文化"
                 data-desc="台灣海洋文化的代表，玄武岩柱地質奇觀">
                <circle cx="152" cy="450" r="7" fill="#2A6E48" opacity="0.2"/>
                <circle cx="152" cy="450" r="5" fill="#2A6E48" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>

              <g class="marker island-marker" data-region="islands" data-category="history"
                 data-title="金門" data-link="/history/戒嚴時期"
                 data-desc="見證兩岸對峙歷史，高粱酒與坑道文化">
                <circle cx="80" cy="400" r="7" fill="#8B6E5A" opacity="0.2"/>
                <circle cx="80" cy="400" r="5" fill="#8B6E5A" stroke="#F8F1E9" stroke-width="1.5" filter="url(#pulseGlow)"/>
              </g>
            </g>
          </svg>

          <!-- Elegant tooltip -->
          <div id="tooltip" class="map-tooltip" role="tooltip" aria-live="polite">
            <div class="tt-category" id="ttCategory"></div>
            <div class="tt-title" id="ttTitle"></div>
            <div class="tt-desc" id="ttDesc"></div>
            <div class="tt-cta">點擊閱讀全文 →</div>
          </div>
        </div><!-- /map-canvas -->
      </div><!-- /map-canvas-wrap -->

      <!-- ── Sidebar ── -->
      <aside class="map-sidebar" id="mapSidebar">

        <!-- Default panel -->
        <div id="defaultPanel">
          <div class="sidebar-header">
            <p class="sidebar-kicker">Knowledge Atlas</p>
            <h2 class="sidebar-title">台灣知識地圖</h2>
            <p class="sidebar-desc">點擊地圖上的節點，探索台灣各地的文化、歷史與自然故事。</p>
          </div>

          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-num" id="totalMarkers">18</span>
              <span class="stat-unit">個</span>
              <span class="stat-lbl">知識節點</span>
            </div>
            <div class="stat-card">
              <span class="stat-num">9</span>
              <span class="stat-unit">個</span>
              <span class="stat-lbl">分類</span>
            </div>
          </div>

          <div class="legend-section">
            <p class="legend-title">分類分布</p>
            <ul class="legend-list">
              <li class="legend-item">
                <span class="legend-dot" style="background:#006D77;"></span>
                <span class="legend-name">自然</span>
                <span class="legend-count">5</span>
              </li>
              <li class="legend-item">
                <span class="legend-dot" style="background:#5E4B8B;"></span>
                <span class="legend-name">文化</span>
                <span class="legend-count">3</span>
              </li>
              <li class="legend-item">
                <span class="legend-dot" style="background:#8B6E5A;"></span>
                <span class="legend-name">歷史</span>
                <span class="legend-count">3</span>
              </li>
              <li class="legend-item">
                <span class="legend-dot" style="background:#C17D5E;"></span>
                <span class="legend-name">美食</span>
                <span class="legend-count">2</span>
              </li>
              <li class="legend-item">
                <span class="legend-dot" style="background:#1A3C34;"></span>
                <span class="legend-name">經濟</span>
                <span class="legend-count">2</span>
              </li>
              <li class="legend-item">
                <span class="legend-dot" style="background:#2A6E48;"></span>
                <span class="legend-name">地理</span>
                <span class="legend-count">2</span>
              </li>
              <li class="legend-item">
                <span class="legend-dot" style="background:#006D77;box-shadow:0 0 0 2px #F8F1E9,0 0 0 3px #006D77;"></span>
                <span class="legend-name">科技</span>
                <span class="legend-count">1</span>
              </li>
              <li class="legend-item">
                <span class="legend-dot" style="background:#A0785A;"></span>
                <span class="legend-name">生活</span>
                <span class="legend-count">1</span>
              </li>
              <li class="legend-item">
                <span class="legend-dot" style="background:#C17D5E;box-shadow:0 0 0 2px #F8F1E9,0 0 0 3px #C17D5E;"></span>
                <span class="legend-name">藝術</span>
                <span class="legend-count">1</span>
              </li>
            </ul>
          </div>

          <div class="sidebar-nav">
            <a href="/graph" class="nav-link nav-link--primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="3"/><circle cx="4" cy="6" r="2"/><circle cx="20" cy="6" r="2"/>
                <circle cx="4" cy="18" r="2"/><circle cx="20" cy="18" r="2"/>
                <line x1="6" y1="6.5" x2="10" y2="10"/><line x1="18" y1="6.5" x2="14" y2="10"/>
                <line x1="6" y1="17.5" x2="10" y2="14"/><line x1="18" y1="17.5" x2="14" y2="14"/>
              </svg>
              知識圖譜
            </a>
            <a href="/" class="nav-link nav-link--ghost">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
              首頁分類
            </a>
          </div>
        </div><!-- /defaultPanel -->

        <!-- Article panel (shown on marker click) -->
        <div id="articlePanel" style="display:none;" class="article-panel">
          <button class="back-btn" id="backBtn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            返回地圖
          </button>
          <div class="article-badge" id="articleBadge"></div>
          <h3 class="article-heading" id="articleTitle"></h3>
          <p class="article-desc" id="articleDesc"></p>
          <a id="articleLink" href="#" class="read-more-link">
            閱讀完整文章
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        </div><!-- /articlePanel -->

      </aside>
    </section>

    <!-- ── Bottom hint ── -->
    <div class="map-hint">
      <p>點擊地圖節點探索故事 · 使用篩選器聚焦感興趣的主題</p>
