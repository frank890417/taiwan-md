<script>
  const categoryColors: Record<string, string> = {
    history:    '#8B6E5A',
    geography:  '#2A6E48',
    culture:    '#5E4B8B',
    food:       '#C17D5E',
    art:        '#C17D5E',
    music:      '#006D77',
    technology: '#006D77',
    nature:     '#006D77',
    people:     '#A0785A',
    society:    '#4A5E52',
    economy:    '#1A3C34',
    lifestyle:  '#A0785A',
  };

  const categoryNames: Record<string, string> = {
    history:    '歷史',
    geography:  '地理',
    culture:    '文化',
    food:       '美食',
    art:        '藝術',
    music:      '音樂',
    technology: '科技',
    nature:     '自然',
    people:     '人物',
    society:    '社會',
    economy:    '經濟',
    lifestyle:  '生活',
  };

  let activeRegion   = 'all';
  let activeCategory = 'all';

  function initMap() {
    const markers        = document.querySelectorAll<SVGGElement>('.marker');
    const tooltip        = document.getElementById('tooltip')!;
    const regionFilters  = document.getElementById('regionFilters')!;
    const categoryFilters = document.getElementById('categoryFilters')!;
    const mapCanvas      = document.getElementById('mapCanvas')!;

    // ── Tooltip on hover ────────────────────────
    markers.forEach(marker => {
      marker.addEventListener('mouseenter', () => {
        const cat  = marker.dataset.category ?? '';
        const title = marker.dataset.title ?? '';
        const desc  = marker.dataset.desc  ?? '';

        document.getElementById('ttCategory')!.textContent = categoryNames[cat] ?? cat;
        document.getElementById('ttTitle')!.textContent    = title;
        document.getElementById('ttDesc')!.textContent     = desc;
        tooltip.style.opacity = '1';
      });

      marker.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = mapCanvas.getBoundingClientRect();
        const x = e.clientX - rect.left + 14;
        const y = e.clientY - rect.top  - 14;
        // keep tooltip inside canvas
        const ttW = 220;
        const ttX = (x + ttW > rect.width) ? x - ttW - 28 : x;
        tooltip.style.left = ttX + 'px';
        tooltip.style.top  = y  + 'px';
      });

      marker.addEventListener('mouseleave', () => {
        tooltip.style.opacity = '0';
      });

      marker.addEventListener('click', () => showArticle(marker));
    });

    // ── Region filter ────────────────────────────
    regionFilters.addEventListener('click', e => {
      const btn = (e.target as Element).closest('.pill');
      if (!btn) return;
      regionFilters.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeRegion = (btn as HTMLElement).dataset.filter ?? 'all';
      applyFilters();
    });

    // ── Category filter ──────────────────────────
    categoryFilters.addEventListener('click', e => {
      const btn = (e.target as Element).closest('.pill');
      if (!btn) return;
      categoryFilters.querySelectorAll('.pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = (btn as HTMLElement).dataset.filter ?? 'all';
      applyFilters();
    });

    // ── Back button ───────────────────────────────
    document.getElementById('backBtn')!.addEventListener('click', () => {
      document.getElementById('defaultPanel')!.style.display = 'block';
      document.getElementById('articlePanel')!.style.display = 'none';
    });
  }

  function applyFilters() {
    const markers = document.querySelectorAll<SVGGElement>('.marker');
    let visible = 0;
    markers.forEach(m => {
      const regionOk   = activeRegion   === 'all' || m.dataset.region   === activeRegion;
      const categoryOk = activeCategory === 'all' || m.dataset.category === activeCategory;
      if (regionOk && categoryOk) {
        m.classList.remove('hidden');
        visible++;
      } else {
        m.classList.add('hidden');
      }
    });
    const el = document.getElementById('totalMarkers');
    if (el) el.textContent = String(visible);
  }

  function showArticle(marker: SVGGElement) {
    const cat   = marker.dataset.category ?? '';
    const title = marker.dataset.title ?? '';
    const desc  = marker.dataset.desc  ?? '';
    const link  = marker.dataset.link  ?? '#';
    const color = categoryColors[cat] ?? '#1A3C34';

    const badge = document.getElementById('articleBadge')!;
    badge.textContent = categoryNames[cat] ?? cat;
    badge.style.background = color + '18';
    badge.style.color       = color;

    document.getElementById('articleTitle')!.textContent = title;
    document.getElementById('articleDesc')!.textContent  = desc;
    (document.getElementById('articleLink') as HTMLAnchorElement).href = link;

    document.getElementById('defaultPanel')!.style.display = 'none';
    document.getElementById('articlePanel')!.style.display = 'block';
  }

  document.addEventListener('DOMContentLoaded', initMap);
</script>
