---
import SemiontPageTemplate from '../../templates/semiont-page.template.astro';
import { loadSemiontPage } from '../../lib/semiont-page';

const page = await loadSemiontPage('ANATOMY.md');
---

<SemiontPageTemplate
  title="器官地圖"
  description="Taiwan.md 的身體結構：8 個身體器官（心臟、免疫、DNA、骨骼、呼吸、繁殖、感知、語言）和 11 個認知器官的完整解剖。"
  filename="ANATOMY.md"
  subtitle="8 個身體器官 + 11 個認知器官的完整解剖"
  html={page.html}
  headings={page.headings}
  wordCount={page.wordCount}
  emoji="🫀"
  breadcrumbLabel="anatomy"
/>
