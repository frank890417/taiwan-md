---
import Layout from '../layouts/Layout.astro';
import { readdir, readFile } from 'fs/promises';
import { resolve, join } from 'path';

// ── Build-time: read all YAML files in data/terminology/ ──────────────────────
import { parse as parseYaml } from 'yaml';

interface TermEntry {
  id: string;
  category: string;
  fork_type: string; // A / B / C / D / E / F
  display: {
    taiwan: string;
    china?: string;
    hongkong?: string;
    southeast_asia?: string;
  };
  english?: string;
  etymology: {
    origin?: string;
    taiwan_path?: string;
    china_path?: string;
    fork_point?: string;
    fork_cause?: string;
  };
  usage?: {
    taiwan_formal?: boolean;
    taiwan_casual?: boolean;
    exceptions?: string;
  };
  status?: string;
  notes?: string;
  sources?: string[];
  added?: string;
  updated?: string;
}

const termDir = resolve(process.cwd(), 'data/terminology');
const files = await readdir(termDir);
const terms: TermEntry[] = [];

for (const file of files) {
  if (!file.endsWith('.yaml') || file.startsWith('_')) continue;
  const raw = await readFile(join(termDir, file), 'utf-8');
  try {
    const d = parseYaml(raw) as TermEntry;
    if (d && d.display && d.display.taiwan) {
      terms.push(d);
    }
  } catch {
    // skip malformed
  }
}

// Sort by fork_type then taiwan display
terms.sort((a, b) => {
  const ft = (a.fork_type || 'Z').localeCompare(b.fork_type || 'Z');
  if (ft !== 0) return ft;
  return (a.display?.taiwan || '').localeCompare(b.display?.taiwan || '', 'zh-TW');
});

const totalTerms = terms.length;
const totalSources = (() => {
  const seen = new Set<string>();
  for (const t of terms) {
    for (const s of (t.sources || [])) if (s) seen.add(s.trim());
  }
  return seen.size;
})();

const forkTypeLabels: Record<string, string> = {
  A: 'A 日語遺產',
  B: 'B 1949分流',
  C: 'C 網路時代',
  D: 'D 台客語底層',
  E: 'E 正在分歧',
  F: 'F 同詞不同語感',
};
const forkTypeColors: Record<string, string> = {
  A: '#e74c3c',
  B: '#3498db',
  C: '#9b59b6',
  D: '#27ae60',
  E: '#f39c12',
  F: '#607d8b',
};

// Pre-process cards data for template (avoid complex expressions in JSX)
interface CardData {
  fork_type: string;
  taiwan: string;
  china: string;
  hongkong: string;
  english: string;
  fork_label: string;
  fork_color: string;
  fork_point: string;
  notes_short: string;
  notes_full: string;
  origin: string;
  taiwan_path: string;
  china_path: string;
  fork_cause: string;
  exceptions: string;
  sources: string[];
}

const cards: CardData[] = terms.map((t) => {
  const forkColor = forkTypeColors[t.fork_type] || '#999';
  const forkLabel = forkTypeLabels[t.fork_type] || t.fork_type;
  const notesClean = (t.notes || '').split('\n').join(' ').trim();
  const notesShort = notesClean.length > 90 ? notesClean.slice(0, 90) + '…' : notesClean;
  return {
    fork_type: t.fork_type || '',
    taiwan: t.display?.taiwan || '',
    china: t.display?.china || '',
    hongkong: t.display?.hongkong || '',
    english: t.english || '',
    fork_label: forkLabel,
    fork_color: forkColor,
    fork_point: t.etymology?.fork_point || '',
    notes_short: notesShort,
    notes_full: notesClean,
    origin: (t.etymology?.origin || '').split('\n').join(' ').trim(),
    taiwan_path: (t.etymology?.taiwan_path || '').split('\n').join(' ').trim(),
    china_path: (t.etymology?.china_path || '').split('\n').join(' ').trim(),
    fork_cause: (t.etymology?.fork_cause || '').split('\n').join(' ').trim(),
    exceptions: (t.usage?.exceptions || '').split('\n').join(' ').trim(),
    sources: (t.sources || []).filter(Boolean),
  };
});

// Serialize for client-side JS
const termsJSON = JSON.stringify(terms);

---

<Layout title="📖 用語保存計畫 — Taiwan.md">
  <main class="term-page">
    <!-- ── Header ─────────────────────────────────────────────── -->
    <div class="term-header">
      <div class="header-inner">
        <h1>📖 用語保存計畫 <span class="header-en">Terminology Preservation</span></h1>
        <p class="header-tagline">
          Taiwan.md 的文字應該讀起來像在台灣長大的人寫的——這不是政治立場，是生活經驗的真實性。
        </p>
        <div class="header-bottom">
          <div class="header-stats">
            <span class="stat"><strong>{totalTerms}</strong> 個詞條</span>
            <span class="stat-sep">|</span>
            <span class="stat"><strong>6</strong> 種分歧類型</span>
            <span class="stat-sep">|</span>
            <span class="stat"><strong>{totalSources}</strong> 個來源</span>
          </div>
          <a href="/fork-graph" class="fork-link-btn">
            🌿 語言分支樹 →
          </a>
        </div>
      </div>
    </div>

    <!-- ── Filter bar ─────────────────────────────────────────── -->
    <div class="filter-bar">
      <div class="filter-inner">
        <div class="filter-buttons" role="group" aria-label="依分歧類型篩選">
          <button class="filter-btn active" data-fork="all">全部</button>
          {Object.entries(forkTypeLabels).map(([key, label]) => (
            <button
              class="filter-btn"
              data-fork={key}
              style={`--fork-color: ${forkTypeColors[key]}`}
            >
              {label}
            </button>
          ))}
        </div>
        <div class="search-wrap">
          <input
            id="term-search"
            type="search"
            placeholder="搜尋詞條…"
            aria-label="搜尋用語詞條"
          />
          <span id="result-count" class="result-count"></span>
        </div>
      </div>
    </div>

    <!-- ── Cards grid ─────────────────────────────────────────── -->
    <div class="terms-section">
      <div class="terms-grid" id="terms-grid">
        {cards.map((c, i) => (
          <div
            class="term-card"
            data-fork={c.fork_type}
            data-taiwan={c.taiwan}
            data-china={c.china}
            data-notes={c.notes_full}
            data-id={`card-${i}`}
            role="article"
            tabindex="0"
            aria-expanded="false"
          >
            <div class="card-top">
              <div class="card-main">
                <span class="taiwan-word">{c.taiwan}</span>
                {c.china && <span class="china-word">中：{c.china}</span>}
                {c.hongkong && <span class="hk-word">港：{c.hongkong}</span>}
              </div>
              <div class="card-meta">
                <button
                  class="fork-tree-btn"
                  title="查看語言分支樹"
                  aria-label={`查看「${c.taiwan}」的語言分支樹`}
                  data-tw={c.taiwan}
                  data-cn={c.china || c.taiwan}
                  data-origin={c.origin || ''}
                  data-fork-point={c.fork_point || ''}
                  data-fork-type={c.fork_type}
                  data-fork-color={c.fork_color}
                  data-tw-path={c.taiwan_path || ''}
                  data-cn-path={c.china_path || ''}
                >🌿</button>
                <span
                  class="fork-badge"
                  style={`background: ${c.fork_color}22; color: ${c.fork_color}; border-color: ${c.fork_color}44`}
                >
                  {c.fork_label}
                </span>
                {c.fork_point && <span class="fork-point">{c.fork_point}</span>}
              </div>
            </div>
            {c.notes_short && <p class="card-notes-short">{c.notes_short}</p>}
            <div class="card-expand" aria-hidden="true">
              <div class="expand-content">
                {c.origin && (
                  <div class="expand-section">
                    <h4>詞源</h4>
                    <p>{c.origin}</p>
                  </div>
                )}
                {c.taiwan_path && (
                  <div class="expand-section">
                    <h4>台灣路徑</h4>
                    <p>{c.taiwan_path}</p>
                  </div>
                )}
                {c.china_path && (
                  <div class="expand-section">
                    <h4>中國路徑</h4>
                    <p>{c.china_path}</p>
                  </div>
                )}
                {c.fork_cause && (
                  <div class="expand-section">
                    <h4>分歧原因</h4>
                    <p>{c.fork_cause}</p>
                  </div>
                )}
                {c.exceptions && (
                  <div class="expand-section">
                    <h4>例外情境</h4>
                    <p>{c.exceptions}</p>
                  </div>
                )}
                {c.sources.length > 0 && (
                  <div class="expand-section sources-section">
                    <h4>來源</h4>
                    <ul>
                      {c.sources.map((src) => <li>{src}</li>)}
                    </ul>
                  </div>
                )}
                {c.english && (
                  <div class="expand-english">
                    English: <em>{c.english}</em>
                  </div>
                )}
              </div>
            </div>
            <button class="expand-toggle" aria-label={`展開 ${c.taiwan} 詞源`}>
              <span class="toggle-text">查看詞源</span>
              <span class="toggle-icon">▼</span>
            </button>
          </div>
        ))}
      </div>
      <p class="no-results" id="no-results" style="display:none">找不到符合條件的詞條。</p>
    </div>

    <!-- ── Footer ─────────────────────────────────────────────── -->
    <div class="term-footer">
      <div class="footer-inner">
        <div class="footer-links">
          <a
            href="https://github.com/taiwan-md/taiwan-md/tree/main/data/terminology"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
          >
            📂 在 GitHub 瀏覽詞條資料
          </a>
          <a href="/contribute" class="footer-link footer-cta">
            ✏️ 貢獻詞條
          </a>
          <a href="/culture/台灣華語的演化" class="footer-link">
            📝 台灣華語的演化
          </a>
        </div>
        <p class="footer-note">
          用語保存計畫持續收錄中。每個詞條都有詞源考據與使用建議。
        </p>
      </div>
    </div>
    <!-- ── Fork Tree Popup ────────────────────────────────────── -->
    <div class="fork-popup-overlay" id="fork-popup" aria-hidden="true">
      <div class="fork-popup-box">
        <button class="fork-popup-close" aria-label="關閉">✕</button>
        <h3 class="fork-popup-title" id="fork-popup-title"></h3>
        <div class="fork-popup-graph">
          <svg id="fork-popup-svg" width="100%" height="180"></svg>
        </div>
        <div class="fork-popup-info" id="fork-popup-info"></div>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ termsJSON }}>
  const terms = JSON.parse(termsJSON);
  const grid = document.getElementById('terms-grid');
  const noResults = document.getElementById('no-results');
  const searchInput = document.getElementById('term-search');
  const resultCount = document.getElementById('result-count');
  const filterBtns = document.querySelectorAll('.filter-btn');

  let currentFork = 'all';
  let currentQuery = '';

  function applyFilters() {
    const cards = grid ? grid.querySelectorAll('.term-card') : [];
    let visible = 0;
    cards.forEach((card) => {
      const fork = card.dataset.fork || '';
      const taiwan = (card.dataset.taiwan || '').toLowerCase();
      const china = (card.dataset.china || '').toLowerCase();
      const notes = (card.dataset.notes || '').toLowerCase();
      const q = currentQuery.toLowerCase();

      const forkMatch = currentFork === 'all' || fork === currentFork;
      const queryMatch =
        !q ||
        taiwan.includes(q) ||
        china.includes(q) ||
        notes.includes(q);

      const show = forkMatch && queryMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (noResults) {
      noResults.style.display = visible === 0 ? 'block' : 'none';
    }
    if (resultCount) {
      resultCount.textContent =
        currentFork !== 'all' || currentQuery
          ? `${visible} 個詞條`
          : '';
    }
  }

  // Filter buttons
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      currentFork = btn.dataset.fork || 'all';
      applyFilters();
    });
  });

  // Search
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      currentQuery = e.target.value;
      applyFilters();
    });
  }

  // Expand/collapse cards
  function toggleCard(card) {
    const isOpen = card.getAttribute('aria-expanded') === 'true';
    card.setAttribute('aria-expanded', String(!isOpen));
    const expand = card.querySelector('.card-expand');
    const toggleText = card.querySelector('.toggle-text');
    const toggleIcon = card.querySelector('.toggle-icon');
    if (expand) {
      expand.style.maxHeight = isOpen ? '0' : expand.scrollHeight + 'px';
      expand.setAttribute('aria-hidden', String(isOpen));
    }
    if (toggleText) toggleText.textContent = isOpen ? '查看詞源' : '收起';
    if (toggleIcon) toggleIcon.style.transform = isOpen ? '' : 'rotate(180deg)';
  }

  document.querySelectorAll('.term-card').forEach((card) => {
    const btn = card.querySelector('.expand-toggle');
    if (btn) {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleCard(card);
      });
    }
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggleCard(card);
      }
    });
  });

  // ── Fork Tree Popup ──────────────────────────────────────────
  const popup = document.getElementById('fork-popup');
  const popupTitle = document.getElementById('fork-popup-title');
  const popupInfo = document.getElementById('fork-popup-info');
  const popupSvg = document.getElementById('fork-popup-svg');
  const popupClose = popup?.querySelector('.fork-popup-close');

  function openForkPopup(btn) {
    const tw = btn.dataset.tw;
    const cn = btn.dataset.cn;
    const origin = btn.dataset.origin;
    const forkPoint = btn.dataset.forkPoint;
    const forkType = btn.dataset.forkType;
    const forkColor = btn.dataset.forkColor;
    const twPath = btn.dataset.twPath;
    const cnPath = btn.dataset.cnPath;

    popupTitle.textContent = `🌿 ${tw}${cn && cn !== tw ? ` / ${cn}` : ''}`;

    // Draw mini fork tree with SVG (no D3 needed for single term)
    const W = 500, H = 160;
    const sameTerm = (!cn || cn === tw);
    popupSvg.setAttribute('viewBox', `0 0 ${W} ${H}`);
    popupSvg.innerHTML = '';

    // Layout: origin node left → fork point center → two branches right
    const ox = 60, oy = H / 2;
    const fx = W * 0.45, fy = H / 2;
    const twX = W - 80, twY = 50;
    const cnX = W - 80, cnY = H - 50;

    // Path: origin → fork
    const pathOriginFork = `M${ox},${oy} C${fx - 40},${oy} ${fx - 40},${fy} ${fx},${fy}`;
    // Path: fork → taiwan
    const pathTW = `M${fx},${fy} C${fx + 60},${fy} ${twX - 60},${twY} ${twX},${twY}`;
    // Path: fork → china
    const pathCN = sameTerm ? '' : `M${fx},${fy} C${fx + 60},${fy} ${cnX - 60},${cnY} ${cnX},${cnY}`;

    const twColor = '#e74c3c';
    const cnColor = '#3498db';
    const originColor = '#888';

    let svg = `
      <path d="${pathOriginFork}" fill="none" stroke="${originColor}" stroke-width="2" stroke-dasharray="6,3"/>
      <path d="${pathTW}" fill="none" stroke="${twColor}" stroke-width="2.5"/>
      ${!sameTerm ? `<path d="${pathCN}" fill="none" stroke="${cnColor}" stroke-width="2.5"/>` : ''}
      <circle cx="${ox}" cy="${oy}" r="6" fill="${originColor}"/>
      <circle cx="${fx}" cy="${fy}" r="5" fill="#555"/>
      <circle cx="${twX}" cy="${twY}" r="7" fill="${twColor}"/>
      ${!sameTerm ? `<circle cx="${cnX}" cy="${cnY}" r="7" fill="${cnColor}"/>` : ''}
      <text x="${ox}" y="${oy - 14}" text-anchor="middle" font-size="11" fill="#888">詞源</text>
      <text x="${fx}" y="${fy - 14}" text-anchor="middle" font-size="10" fill="#888">${forkPoint || '分歧點'}</text>
      <text x="${twX}" y="${twY - 14}" text-anchor="middle" font-size="12" font-weight="700" fill="${twColor}">🇹🇼 ${tw}</text>
      ${!sameTerm ? `<text x="${cnX}" y="${cnY + 22}" text-anchor="middle" font-size="12" font-weight="700" fill="${cnColor}">🇨🇳 ${cn}</text>` : ''}
    `;

    if (sameTerm) {
      // F type: same word, different feel
      svg += `<text x="${twX}" y="${twY + 20}" text-anchor="middle" font-size="10" fill="#888">同詞不同語感</text>`;
    }

    popupSvg.innerHTML = svg;

    // Info section
    let info = '';
    if (origin) info += `<div class="info-row"><span class="info-label">詞源</span><span>${origin}</span></div>`;
    if (twPath) info += `<div class="info-row"><span class="info-label">🇹🇼 台灣</span><span>${twPath}</span></div>`;
    if (cnPath) info += `<div class="info-row"><span class="info-label">🇨🇳 中國</span><span>${cnPath}</span></div>`;
    popupInfo.innerHTML = info;

    popup.classList.add('visible');
    popup.setAttribute('aria-hidden', 'false');
  }

  function closeForkPopup() {
    popup.classList.remove('visible');
    popup.setAttribute('aria-hidden', 'true');
  }

  // Bind click events
  document.querySelectorAll('.fork-tree-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      openForkPopup(btn);
    });
  });

  popupClose?.addEventListener('click', closeForkPopup);
  popup?.addEventListener('click', (e) => {
    if (e.target === popup) closeForkPopup();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && popup?.classList.contains('visible')) closeForkPopup();
  });
</script>

<style>
  /* ── Fork Link Button (in header) ────────────────────────────── */
  .header-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .fork-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    background: rgba(255,255,255,0.12);
    color: white;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 600;
    transition: background 0.15s, border-color 0.15s;
    white-space: nowrap;
  }
  .fork-link-btn:hover {
    background: rgba(255,255,255,0.2);
    border-color: rgba(255,255,255,0.4);
    text-decoration: none;
  }

  /* ── Page layout ──────────────────────────────────────────────── */
  .term-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: #f8f8f8;
  }

  /* ── Header ──────────────────────────────────────────────────── */
  .term-header {
    background: #1a1a2e;
    color: white;
    padding: 2.5rem var(--space-page-x, 2rem) 2rem;
  }
  .header-inner {
    max-width: 72rem;
    margin: 0 auto;
  }
  .term-header h1 {
    font-family: var(--font-editorial, Georgia, serif);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }
  .header-en {
    font-size: 0.62em;
    font-weight: 400;
    opacity: 0.65;
    display: block;
    margin-top: 0.2em;
    letter-spacing: 0.04em;
    font-family: var(--font-ui, system-ui, sans-serif);
  }
  .header-tagline {
    font-size: clamp(0.9rem, 1.8vw, 1.05rem);
    opacity: 0.82;
    margin: 0 0 1.25rem;
    max-width: 42rem;
    line-height: 1.65;
  }
  .header-stats {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
    opacity: 0.75;
  }
  .stat strong {
    color: white;
    opacity: 1;
    font-size: 1.05em;
  }
  .stat-sep {
    opacity: 0.4;
  }

  /* ── Filter bar ──────────────────────────────────────────────── */
  .filter-bar {
    background: white;
    border-bottom: 1px solid #e5e5e5;
    position: sticky;
    top: 0;
    z-index: 10;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .filter-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.85rem var(--space-page-x, 2rem);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    flex: 1;
  }
  .filter-btn {
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1.5px solid #ddd;
    background: white;
    font-size: 0.82rem;
    cursor: pointer;
    color: #444;
    transition: all 0.15s;
    font-family: inherit;
    white-space: nowrap;
  }
  .filter-btn:hover {
    border-color: var(--fork-color, #3498db);
    color: var(--fork-color, #3498db);
    background: color-mix(in srgb, var(--fork-color, #3498db) 8%, white);
  }
  .filter-btn.active {
    background: var(--fork-color, #1a1a2e);
    border-color: var(--fork-color, #1a1a2e);
    color: white;
  }
  .filter-btn[data-fork="all"].active {
    background: #1a1a2e;
    border-color: #1a1a2e;
  }
  .search-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 180px;
  }
  #term-search {
    padding: 0.38rem 0.8rem;
    border: 1.5px solid #ddd;
    border-radius: 6px;
    font-size: 0.9rem;
    outline: none;
    width: 180px;
    transition: border-color 0.2s;
    font-family: inherit;
  }
  #term-search:focus {
    border-color: #1a1a2e;
  }
  .result-count {
    font-size: 0.8rem;
    color: #888;
    white-space: nowrap;
  }

  /* ── Grid ────────────────────────────────────────────────────── */
