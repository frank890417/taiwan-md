---
import Layout from '../../layouts/Layout.astro';
import { readdir, readFile } from 'fs/promises';
import { resolve, join } from 'path';
import { parse as parseYaml } from 'yaml';
import { createRequire } from 'module';

// ── Build-time: s2t converter for normalizing china values ────────────────────
// We use opencc-js at build time to convert any simplified Chinese china values
// to traditional Chinese, since the frontend OpenCC already converts input text
// from simplified → traditional before matching against our rules.
let s2tConverter: ((text: string) => string) | null = null;
try {
  const require = createRequire(import.meta.url);
  const OpenCC = require('opencc-js');
  // Converter({from:'cn', to:'tw'}) converts simplified→traditional (Taiwan standard)
  // This matches what the frontend does before terminology matching
  // Both build-time and frontend must use the same conversion to ensure rules match
  s2tConverter = OpenCC.Converter({ from: 'cn', to: 'tw' });
} catch {
  console.warn(
    '[converter.astro] opencc-js not available, china values may not match simplified input',
  );
}

function toTraditional(text: string): string {
  if (!s2tConverter) return text;
  try {
    return s2tConverter(text);
  } catch {
    return text;
  }
}

/**
 * Extract the primary source term from a china value that may contain
 * slash-separated variants or parenthetical annotations.
 * This mirrors the logic in scripts/tools/terminology-clean.py.
 */
function cleanChinaSource(raw: string): string {
  if (!raw || raw.startsWith('N/A') || raw.startsWith('（無')) return raw;
  let s = raw;
  // Remove parenthetical annotations like （簡）（中國）（舊）etc.
  s = s.replace(/（[^）]*）/g, '');
  s = s.replace(/\([^)]*\)/g, '');
  // Take first variant if slash-separated
  if (s.includes('/')) {
    s = s.split('/')[0];
  }
  return s.trim();
}

// ── Build-time: generate conversion rules from YAML files ─────────────────────
interface TermEntry {
  id: string;
  category?: string;
  subcategory?: string;
  fork_type?: string;
  display: {
    taiwan: string;
    china?: string;
    hongkong?: string;
  };
  notes?: string;
  sources?: string[];
}

interface ConversionRule {
  source: string;
  target: string;
  forkType: string;
  category: string;
  id: string;
}

const termDir = resolve(process.cwd(), 'data/terminology');
const files = await readdir(termDir);
const rules: ConversionRule[] = [];
// Track seen sources to avoid duplicates
const seenSources = new Set<string>();

for (const file of files) {
  if (!file.endsWith('.yaml') || file.startsWith('_')) continue;
  const raw = await readFile(join(termDir, file), 'utf-8');
  try {
    const d = parseYaml(raw) as TermEntry;
    // Support both display.{china,taiwan} and top-level {china,taiwan} formats
    const chinaVal = d?.display?.china || (d as any)?.china;
    const taiwanVal = d?.display?.taiwan || (d as any)?.taiwan;
    if (d && chinaVal && taiwanVal && chinaVal !== taiwanVal) {
      const forkType = d.fork_type || (d as any)?.type || '';
      const category = d.category || '';
      const id = d.id || file.replace('.yaml', '');
      const target = taiwanVal;
      const chinaRaw = chinaVal;

      // Step 1: Clean the raw china value (strip annotations, take first slash variant)
      const chinaCleaned = cleanChinaSource(chinaRaw);

      // Skip if value is N/A, （無直接對應）, or cleaned result equals taiwan
      if (!chinaCleaned || chinaCleaned === target) continue;
      if (chinaCleaned.startsWith('N/A') || chinaCleaned.startsWith('（無'))
        continue;

      // Step 2: Normalize to traditional Chinese so it matches
      // the frontend's OpenCC-converted input text
      const chinaTraditional = toTraditional(chinaCleaned);

      // Add rule for the traditional form (the primary matching source)
      if (!seenSources.has(chinaTraditional) && chinaTraditional !== target) {
        rules.push({
          source: chinaTraditional,
          target,
          forkType,
          category,
          id,
        });
        seenSources.add(chinaTraditional);
      }

      // If the original simplified form differs from traditional, also add
      // a fallback rule for the simplified form (for when OpenCC is unavailable)
      if (
        chinaCleaned !== chinaTraditional &&
        !seenSources.has(chinaCleaned) &&
        chinaCleaned !== target
      ) {
        rules.push({
          source: chinaCleaned,
          target,
          forkType,
          category,
          id: id + '_simp',
        });
        seenSources.add(chinaCleaned);
      }
    }
  } catch {
    // skip malformed
  }
}

// Sort by source length descending (longer matches first to avoid partial replacement)
rules.sort((a, b) => b.source.length - a.source.length);

const rulesJSON = JSON.stringify(rules);
---

<Layout
  title="台灣用語轉換器：中國用語一鍵轉台灣說法"
  description={`免費線上台灣用語轉換工具。「視頻」→「影片」、「軟件」→「軟體」、「打車」→「叫計程車」——${rules.length} 條轉換規則涵蓋科技、生活、醫療、校園等分類，附台灣化指數分析。不只轉字形，轉的是語感。`}
>
  <!-- Preload OpenCC for faster mobile loading -->
  <link
    rel="modulepreload"
    href="https://cdn.jsdelivr.net/npm/opencc-js@1/dist/esm/cn2t.js"
  />
  <!--
    Phase 6 partial migration — terminology/converter.astro
    ───────────────────────────────────────────────────────
    Wrappers, header, body, editor grid, action bar, analysis box
    moved to inline Tailwind. Kept in scoped <style>:
    - :global(mark.source-word / replaced-word / sample-mark)
      because marks are rendered via innerHTML by the JS converter
    - .change-list / .change-item / .change-source etc.
      because the analysis rows are created in JS and styled via
