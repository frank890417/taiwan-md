        </p>
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div
            class="flex items-center gap-[0.6rem] text-[0.9rem] opacity-80 [&_strong]:text-white [&_strong]:opacity-100"
          >
            <span><strong>{rules.length}</strong> 條轉換規則</span>
          </div>
          <div class="flex flex-wrap gap-2">
            <a
              href="/terminology"
              class="inline-flex items-center gap-[0.4rem] whitespace-nowrap rounded-lg border border-white/25 bg-white/10 px-4 py-[0.45rem] text-[0.88rem] font-semibold text-white no-underline transition-[background,border-color] duration-150 hover:border-white/40 hover:bg-white/20 hover:no-underline"
