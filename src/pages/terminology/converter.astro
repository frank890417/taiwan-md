          <div class="border-b border-[#f0f0f0] pb-3">
            <span
              id="analysis-title"
              class="text-[1.05rem] font-bold text-[#1a1a2e]"></span>
          </div>

          <div
            id="opencc-status"
            class="opencc-status-row mb-1 rounded-md px-3 py-[0.4rem] text-[0.88rem] font-semibold"
