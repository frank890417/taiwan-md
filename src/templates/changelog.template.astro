---
import CommitLog from '../components/commits/CommitLog.astro';
import Layout from '../layouts/Layout.astro';
import { fetchCommitFeed } from '../lib/commits';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { commits, source } = await fetchCommitFeed(100);

const sourceLabel =
  lang === 'zh-TW'
    ? source === 'git'
      ? '來自專案 git 紀錄'
      : source === 'cache'
        ? '來自 build 時快取的 commit feed'
        : source === 'github'
          ? '來自 GitHub commit feed'
          : '目前無法取得更新資料'
    : source === 'git'
      ? 'From local git history'
      : source === 'cache'
        ? 'From the build-time cached commit feed'
        : source === 'github'
          ? 'From the GitHub commit feed'
          : 'Updates are temporarily unavailable';
---

<Layout
  title={t('changelog.meta.title')}
  description={t('changelog.meta.description')}
  lang={lang}
>
  <div
    class="mx-auto max-w-[800px] px-8 pb-24 pt-16 max-[768px]:px-4 max-[768px]:pb-16 max-[768px]:pt-12"
  >
    <header class="mb-16 text-center">
      <h1
        class="mb-3 font-['jf-jinxuanlatte','Noto_Sans_TC','Source_Han_Sans_TC',sans-serif] text-[2.5rem] font-black tracking-[0.05em] text-[#1a1a2e] max-[768px]:text-[2rem]"
      >
        {t('changelog.header.title')}
      </h1>
      <p class="mb-4 text-[1.15rem] font-medium text-[#64748b]">
        {t('changelog.header.subtitle')}
      </p>
      <p
        class="text-[0.9rem] text-[#94a3b8] [&>a:hover]:underline [&>a]:text-[#3b82f6] [&>a]:no-underline"
      >
        {lang === 'zh-TW' ? '共 ' : ''}{commits.length}{' '}
        {t('changelog.header.meta.updates')} · {sourceLabel} ·
        <a
          href="https://github.com/frank890417/taiwan-md/commits/main"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
      </p>
    </header>

    <CommitLog
      commits={commits}
      lang={lang}
      variant="timeline"
      locale={t('changelog.locale')}
      dayUpdatesLabel={t('changelog.day.updates')}
      emptyTitle={lang === 'zh-TW'
        ? '目前暫時抓不到更新紀錄'
        : 'Update history is temporarily unavailable'}
      emptyDescription={lang === 'zh-TW'
        ? '這頁現在會優先讀取 git，失敗時會退回 build-time 快取與 GitHub，避免部署後整頁空白。'
        : 'This page now prefers git, then falls back to a build-time cache and GitHub to avoid shipping an empty changelog.'}
      emptyLinkHref="https://github.com/frank890417/taiwan-md/commits/main"
      emptyLinkLabel="GitHub"
      relativeTimeLabels={{
        justNow: t('changelog.time.just-now'),
        minutesAgo: t('changelog.time.minutes-ago'),
        hoursAgo: t('changelog.time.hours-ago'),
        daysAgo: t('changelog.time.days-ago'),
      }}
    />
  </div>
</Layout>
